{% comment %}
  Video Carousel Standalone Snippet
  
  Customization parameters:
  - heading: Heading text for the carousel (default: "See it in action")
  - heading_size: Font size for the heading (default: 24)
  - heading_color: Color of the heading text (default: #333333)
  - button_color: Background color of the play button (default: #000000, maintains 60% alpha transparency)
  - show_social_badge: Whether to show the social media badge (default: false)
  - social_platform: Platform to show badge for ('tiktok' or 'instagram') (default: 'tiktok')
  - view_count: Number to show in the view counter (default: 5.6)
  - enable_autoplay: Whether videos should autoplay automatically (default: false)
  - show_sound_controls_autoplay: Whether to show sound controls when autoplay is enabled (default: false)
  - hide_scrollbar: Whether to hide the carousel scrollbar (default: false)
{% endcomment %}

<div class="video-carousel-container" data-enable-autoplay="{{ enable_autoplay | default: false }}" data-show-sound-controls="{{ show_sound_controls_autoplay | default: false }}" data-play-button-size="{{ play_button_size | default: 30 }}" data-sound-button-size="{{ sound_button_size | default: 30 }}" data-play-button-bg-color="{{ play_button_bg_color | default: '#000000' }}" data-play-button-bg-opacity="{{ play_button_bg_opacity | default: 35 }}" data-sound-button-bg-color="{{ sound_button_bg_color | default: '#000000' }}" data-sound-button-bg-opacity="{{ sound_button_bg_opacity | default: 35 }}" {{ block.shopify_attributes }}>
  <h2 class="carousel-heading" style="color: {{ heading_color | default: '#333333' }} ; font-size: {{ heading_size | default: 24 }}px ;">{{ heading | default: "See it in action" }}</h2>
  
  {% if show_social_badge %}
    {% if social_platform == 'tiktok' %}
    <div class="tiktok-views-badge" style="{% unless use_gradient_text %} color: {{ badge_text_color | default: '#262626' }} ;{% endunless %}">
      <img class="tiktok-icon" src="https://cdn4.iconfinder.com/data/icons/social-media-flat-7/64/Social-media_Tiktok-512.png" width="12" height="12" alt="TikTok" />
      <span class="tiktok-text {% if use_gradient_text %}gradient-text{% endif %}">{{ badge_text | default: 'Over ' }} {{ view_count }}{{ badge_suffix | default: 'M Views On TikTok' }}</span>
    </div>
    {% elsif social_platform == 'instagram' %}
    <div class="instagram-views-badge" style="{% unless use_gradient_text %} color: {{ badge_text_color | default: '#262626' }} ;{% endunless %}">
      <svg class="instagram-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="instagramGradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#833ab4" />
            <stop offset="50%" stop-color="#fd1d1d" />
            <stop offset="100%" stop-color="#fcb045" />
          </linearGradient>
        </defs>
        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" fill="url(#instagramGradient)"/>
      </svg>
      <span class="instagram-text {% if use_gradient_text %}gradient-text instagram-gradient{% endif %}">{{ badge_text | default: 'Over ' }} {{ view_count }}{{ badge_suffix | default: 'M Views On Instagram' }}</span>
    </div>
    {% elsif social_platform == 'facebook' %}
    <div class="facebook-views-badge" style="{% unless use_gradient_text %} color: {{ badge_text_color | default: '#262626' }} ;{% endunless %}">
      <svg class="facebook-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" fill="#1877F2"/>
      </svg>
      <span class="facebook-text {% if use_gradient_text %}gradient-text facebook-gradient{% endif %}">{{ badge_text | default: 'Over ' }} {{ view_count }}{{ badge_suffix | default: 'M Views On Facebook' }}</span>
    </div>
    {% endif %}
  {% endif %}
  
  <div class="video-carousel">
    {% for video_block in section.blocks %}
      {% if video_block.type == 'carousel_default_video' %}
        <div class="video-item" data-video-id="{{ video_block.id }}" {{ video_block.shopify_attributes }}>
          <div class="video-thumbnail">
            <div class="gradient-overlay"></div>
            {% if video_block.settings.video != blank %}
              {% assign poster_url = video_block.settings.video | img_url: '700x' %}
              <div class="shopify-video-container">
                <img class="carousel-video" src="{{ poster_url }}" alt="Video thumbnail" loading="lazy" width="" height="">
                <div class="video-type" data-type="shopify" data-video-id="{{ video_block.settings.video.id }}"></div>
                <div style="display: none;" class="hidden-video-data">
                  {{ video_block.settings.video | video_tag: controls: false, autoplay: false, loop: true, muted: true, preload: 'metadata' }}
                </div>
              </div>
              <div class="video-play-overlay">
                <button class="testimonial-play-button" aria-label="Play video">
                  <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </button>
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

<!-- Video Modal -->
<div id="videoModal" class="video-modal" style="display: none;">
  <div class="video-modal-content">
    <button type="button" class="close-modal" aria-label="Close video">&times;</button>
    <div class="video-container"></div>
  </div>
</div>

{{ 'video-carousel.js' | asset_url | script_tag }}

<style>
  .video-carousel-container {
    width: 100%;
    overflow: hidden;
    position: relative;
    z-index: 1;
  }
  
  .carousel-heading {
    margin-bottom: 5px;
    margin-top: 0;
    font-weight: var(--font-weight-semibold) ;
    letter-spacing: var(--letter-spacing-heading);
  }
  
  .tiktok-views-badge {
    display: inline-flex ;
    align-items: center ;
    padding: 4px 14px ;
    background-color: transparent ;
    border-radius: 999px ;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif ;
    font-size: 11px ;
    color: #262626 ;
    position: relative ;
    border: none ;
    margin-bottom: 10px ;
    z-index: 999 ;
    visibility: visible ;
    opacity: 1 ;
    overflow: visible ;
  }
  
  .tiktok-views-badge::before {
    content: '' ;
    position: absolute ;
    top: 0 ;
    right: 0 ;
    bottom: 0 ;
    left: 0 ;
    z-index: -1 ;
    border-radius: 999px ;
    background: linear-gradient(45deg, #00f2ea, #ff0050) ;
  }
  
  .tiktok-views-badge::after {
    content: '' ;
    position: absolute ;
    top: 1px ;
    right: 1px ;
    bottom: 1px ;
    left: 1px ;
    z-index: -1 ;
    border-radius: 999px ;
    background-color: {{ badge_background_color | default: '#f8f9fa' }} ;
  }
  
  .tiktok-icon {
    width: 12px ;
    height: 12px ;
    margin-right: 8px ;
    margin-left: 1px ;
    flex-shrink: 0 ;
  }
  
  .tiktok-text {
    letter-spacing: -0.3px ;
    font-weight: 500 ;
  }
  
  /* Gradient Text Classes */
  .gradient-text {
    background-clip: text ;
    -webkit-background-clip: text ;
    -webkit-text-fill-color: transparent ;
    color: transparent ;
    display: inline-block ;
    background-size: 100% 100% ;
    background-repeat: no-repeat ;
    background-attachment: scroll ;
    -webkit-box-decoration-break: clone ;
    box-decoration-break: clone ;
  }
  
  /* TikTok Gradient (default) */
  .tiktok-text.gradient-text {
    background: linear-gradient(45deg, #00f2ea, #ff0050) ;
    background-clip: text ;
    -webkit-background-clip: text ;
  }
  
  /* Instagram Gradient */
  .instagram-text.gradient-text.instagram-gradient {
    background: linear-gradient(45deg, #833ab4, #fd1d1d, #fcb045) ;
    background-clip: text ;
    -webkit-background-clip: text ;
  }
  
  /* Facebook Gradient */
  .facebook-text.gradient-text.facebook-gradient {
    background: linear-gradient(45deg, #1877F2, #42a5f5) ;
    background-clip: text ;
    -webkit-background-clip: text ;
  }
  
  /* Instagram Badge Styling */
  .instagram-views-badge {
    display: inline-flex ;
    align-items: center ;
    padding: 4px 14px ;
    background-color: transparent ;
    border-radius: 999px ;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif ;
    font-size: 11px ;
    color: #262626 ;
    position: relative ;
    border: none ;
    margin-bottom: 10px ;
    z-index: 999 ;
    visibility: visible ;
    opacity: 1 ;
    overflow: visible ;
  }
  
  .instagram-views-badge::before {
    content: '' ;
    position: absolute ;
    top: 0 ;
    right: 0 ;
    bottom: 0 ;
    left: 0 ;
    z-index: -1 ;
    border-radius: 999px ;
    background: linear-gradient(45deg, #833ab4, #fd1d1d, #fcb045) ;
  }
  
  .instagram-views-badge::after {
    content: '' ;
    position: absolute ;
    top: 1px ;
    right: 1px ;
    bottom: 1px ;
    left: 1px ;
    z-index: -1 ;
    border-radius: 999px ;
    background-color: {{ badge_background_color | default: '#f8f9fa' }} ;
  }
  
  /* Facebook Badge Styling */
  .facebook-views-badge {
    display: inline-flex ;
    align-items: center ;
    padding: 4px 14px ;
    background-color: transparent ;
    border-radius: 999px ;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif ;
    font-size: 11px ;
    color: #262626 ;
    position: relative ;
    border: none ;
    margin-bottom: 10px ;
    z-index: 999 ;
    visibility: visible ;
    opacity: 1 ;
    overflow: visible ;
  }
  
  .facebook-views-badge::before {
    content: '' ;
    position: absolute ;
    top: 0 ;
    right: 0 ;
    bottom: 0 ;
    left: 0 ;
    z-index: -1 ;
    border-radius: 999px ;
    background: linear-gradient(45deg, #1877F2, #42a5f5) ;
  }
  
  .facebook-views-badge::after {
    content: '' ;
    position: absolute ;
    top: 1px ;
    right: 1px ;
    bottom: 1px ;
    left: 1px ;
    z-index: -1 ;
    border-radius: 999px ;
    background-color: {{ badge_background_color | default: '#f8f9fa' }} ;
  }
  
  .video-carousel {
    display: flex;
    overflow-x: auto;
    gap: 4px;
    padding: 5px 0;
    padding-bottom: 10px;
    scroll-behavior: smooth;
    {% if hide_scrollbar %}
    -ms-overflow-style: none;
    scrollbar-width: none ;
    {% else %}
    -ms-overflow-style: none;
    scrollbar-width: thin ;
    scrollbar-color: {% if section.settings.use_theme_colors %}{{ settings.global_section_accent_1_color }}{% else %}{{ scrollbar_color | default: "#04C7FF" }}{% endif %} #f0f0f0 ;
    {% endif %}
    position: relative;
    z-index: 1;
  }
  
  {% unless hide_scrollbar %}
  .video-carousel::-webkit-scrollbar {
    height: {{ scrollbar_width | default: 9 }}px;
    background-color: #f0f0f0;
  }
  
  .video-carousel::-webkit-scrollbar-track {
    background: transparent ;
    border-radius: 3px ;
  }
  
  .video-carousel::-webkit-scrollbar-thumb {
    background-color: {% if section.settings.use_theme_colors %}{{ settings.global_section_accent_1_color }}{% else %}{{ scrollbar_color | default: "#04C7FF" }}{% endif %};
    border-radius: 4px;
  }
  {% else %}
  .video-carousel::-webkit-scrollbar {
    display: none;
  }
  {% endunless %}
  
  .video-item {
    flex: 0 0 {{ video_size | default: 130 }}px ;
    width: {{ video_size | default: 130 }}px ;
    position: relative ;
    min-width: {{ video_size | default: 130 }}px ;
    max-width: {{ video_size | default: 130 }}px ;
    margin: 0 ;
    padding: 0 ;
    box-sizing: border-box ;
  }
  
  .video-thumbnail {
    position: relative ;
    border-radius: 6px ;
    overflow: hidden ;
    height: {{ video_size | default: 130 | times: 1.78 | round }}px ;
    background-color: #f0f0f0 ;
    width: 100% ;
    margin: 0 ;
    padding: 0 ;
  }
  
  .gradient-overlay {
    position: absolute ;
    top: 0 ;
    left: 0 ;
    width: 100% ;
    height: 70px ;
    background: linear-gradient(to bottom, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0) 100%) ;
    z-index: 1 ;
    pointer-events: none ;
  }
  
  .carousel-video {
    width: 100% ;
    height: 100% ;
    display: block ;
    object-fit: cover ;
    background-color: #f0f0f0 ;
  }
  
  .video-play-overlay {
    position: absolute ;
    bottom: 8px ;
    left: 8px ;
    width: auto ;
    height: auto ;
    display: flex ;
    align-items: center ;
    justify-content: flex-start ;
    z-index: 10 ;
    pointer-events: none ;
  }

  .video-carousel-container .testimonial-play-button {
    width: {{ play_button_size | default: 30 }}px ;
    height: {{ play_button_size | default: 30 }}px ;
    border-radius: 50% ;
    background: rgba({{ play_button_bg_color | default: '#000000' | color_extract: 'red' }}, {{ play_button_bg_color | default: '#000000' | color_extract: 'green' }}, {{ play_button_bg_color | default: '#000000' | color_extract: 'blue' }}, {{ play_button_bg_opacity | default: 35 | divided_by: 100.0 }}) ;
    border: none ;
    display: flex ;
    align-items: center ;
    justify-content: center ;
    cursor: pointer ;
    transition: transform 0.2s ease, background 0.2s ease ;
    pointer-events: auto ;
  }

  .video-carousel-container .testimonial-play-button:hover {
    transform: scale(1.1) ;
    background: rgba({{ play_button_bg_color | default: '#000000' | color_extract: 'red' }}, {{ play_button_bg_color | default: '#000000' | color_extract: 'green' }}, {{ play_button_bg_color | default: '#000000' | color_extract: 'blue' }}, {{ play_button_bg_opacity | default: 35 | plus: 16 | divided_by: 100.0 }}) ;
  }

  .video-carousel-container .testimonial-play-button svg {
    width: {{ play_button_size | default: 30 | times: 0.8 | round }}px ;
    height: {{ play_button_size | default: 30 | times: 0.8 | round }}px ;
    fill: #ffffff ;
    margin-left: 1px ;
  }
  
  /* Inline video styles */
  .inline-video-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 5;
    border-radius: 6px;
    overflow: hidden;
  }
  
  .inline-video-container iframe,
  .inline-video-container video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
    border-radius: 6px;
    object-fit: cover;
  }
  
  .video-carousel-container .video-sound-button {
    position: absolute ;
    bottom: 8px ;
    right: 8px ;
    width: {{ sound_button_size | default: 30 }}px ;
    height: {{ sound_button_size | default: 30 }}px ;
    border-radius: 50% ;
    background: rgba({{ sound_button_bg_color | default: '#000000' | color_extract: 'red' }}, {{ sound_button_bg_color | default: '#000000' | color_extract: 'green' }}, {{ sound_button_bg_color | default: '#000000' | color_extract: 'blue' }}, {{ sound_button_bg_opacity | default: 35 | divided_by: 100.0 }}) ;
    border: none ;
    display: flex ;
    align-items: center ;
    justify-content: center ;
    cursor: pointer ;
    z-index: 20 ;
    transition: transform 0.2s ease, background 0.2s ease ;
  }
  
  .video-carousel-container .video-sound-button:hover {
    transform: scale(1.1) ;
    background: rgba({{ sound_button_bg_color | default: '#000000' | color_extract: 'red' }}, {{ sound_button_bg_color | default: '#000000' | color_extract: 'green' }}, {{ sound_button_bg_color | default: '#000000' | color_extract: 'blue' }}, {{ sound_button_bg_opacity | default: 35 | plus: 16 | divided_by: 100.0 }}) ;
  }
  
  .video-carousel-container .video-sound-button svg {
    width: {{ sound_button_size | default: 30 | times: 0.67 | round }}px ;
    height: {{ sound_button_size | default: 30 | times: 0.67 | round }}px ;
    fill: white ;
  }
  
  .video-playing .video-play-overlay {
    display: flex ;
  }
  
  .video-carousel-container[data-enable-autoplay="true"] .video-play-overlay {
    display: none ;
  }
  
  .video-carousel-container[data-show-sound-controls="false"] .video-sound-button {
    display: none ;
  }
  
  /* Modal styles - hidden since we're using inline playback */
  .video-modal {
    display: none ;
  }
  

  .instagram-icon {
    width: 12px ;
    height: 12px ;
    margin-right: 8px ;
    margin-left: 1px ;
    flex-shrink: 0 ;
  }

  .instagram-text {
    letter-spacing: -0.3px ;
    font-weight: 500 ;
  }
  
  
  .facebook-icon {
    width: 12px ;
    height: 12px ;
    margin-right: 8px ;
    margin-left: 1px ;
    flex-shrink: 0 ;
  }
  
  .facebook-text {
    letter-spacing: -0.3px ;
    font-weight: 500 ;
  }
  
  @media (max-width: 768px) {
    .tiktok-views-badge,
    .instagram-views-badge,
    .facebook-views-badge {
      font-size: 11px ;
      padding: 1.7px 12px ;
    }
    
    .tiktok-icon,
    .instagram-icon,
    .facebook-icon {
      width: 11.7px ;
      height: 11.7px ;
      margin-right: 7.5px ;
    }
  }
</style>