<style>
  .rr-wishlist { font-family: 'Jost', var(--font-body-family), sans-serif; }

  .rr-wishlist__hero {
    background: #111111; padding: 72px 52px 60px;
    text-align: center; position: relative; overflow: hidden;
  }
  .rr-wishlist__hero::before {
    content: ''; position: absolute; top: -120px; left: 50%; transform: translateX(-50%);
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(184,149,106,0.08) 0%, transparent 65%);
    pointer-events: none;
  }
  .rr-wishlist__eyebrow {
    font-size: 10px; font-weight: 500; letter-spacing: 3.5px;
    text-transform: uppercase; color: #B8956A; margin-bottom: 12px;
  }
  .rr-wishlist__title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(34px, 4.5vw, 52px); font-weight: 300;
    color: #FFFFFF; line-height: 1.1; margin-bottom: 10px;
  }
  .rr-wishlist__sub { font-size: 13px; color: rgba(255,255,255,0.38); }
  .rr-wishlist__count-badge {
    display: inline-block; margin-top: 16px;
    background: rgba(184,149,106,0.15); border: 1px solid rgba(184,149,106,0.3);
    color: #D4B896; font-size: 11px; font-weight: 500; letter-spacing: 1px;
    padding: 5px 16px; border-radius: 20px;
  }

  .rr-wishlist__body { background: #F7F3EE; padding: 52px 52px 80px; }
  .rr-wishlist__body-inner { max-width: 1340px; margin: 0 auto; }

  /* Grid */
  .rr-wishlist__grid {
    display: grid; grid-template-columns: repeat(4,1fr); gap: 20px;
  }
  .rr-wishlist__card {
    background: #fff; border-radius: 16px; overflow: hidden;
    border: 1px solid rgba(0,0,0,0.05);
    transition: all 0.35s; position: relative;
  }
  .rr-wishlist__card:hover { transform: translateY(-5px); box-shadow: 0 24px 60px rgba(0,0,0,0.1); border-color: rgba(184,149,106,0.15); }
  .rr-wishlist__card-img {
    aspect-ratio: 3/4; overflow: hidden;
    background: linear-gradient(160deg, #EDE7DF, #e8e0d6);
    position: relative;
  }
  .rr-wishlist__card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; display: block; }
  .rr-wishlist__card:hover .rr-wishlist__card-img img { transform: scale(1.04); }

  /* Remove button */
  .rr-wishlist__remove {
    position: absolute; top: 10px; right: 10px; z-index: 3;
    width: 30px; height: 30px;
    background: rgba(255,255,255,0.9); border: none; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; color: #555; font-size: 14px; line-height: 1;
    transition: all 0.2s; box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }
  .rr-wishlist__remove:hover { background: #c0392b; color: #fff; }

  .rr-wishlist__card-info { padding: 16px 16px 18px; }
  .rr-wishlist__card-name {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 18px; font-weight: 500; color: #1A1A1A;
    margin-bottom: 4px; line-height: 1.2; text-decoration: none; display: block;
  }
  .rr-wishlist__card-name:hover { color: #B8956A; }
  .rr-wishlist__card-type { font-size: 11px; color: #8A8A8A; margin-bottom: 10px; }
  .rr-wishlist__card-bottom { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .rr-wishlist__card-price { font-size: 15px; font-weight: 600; color: #1A1A1A; }
  .rr-wishlist__card-price del { color: #8A8A8A; font-weight: 400; font-size: 12px; margin-left: 4px; }
  .rr-wishlist__add-btn {
    padding: 8px 16px;
    background: #1A1A1A; color: #fff; border: none;
    font-family: 'Jost', var(--font-body-family), sans-serif;
    font-size: 9px; font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase;
    cursor: pointer; transition: background 0.25s; white-space: nowrap;
  }
  .rr-wishlist__add-btn:hover { background: #B8956A; }

  /* Empty */
  .rr-wishlist__empty {
    text-align: center; padding: 80px 20px;
  }
  .rr-wishlist__empty-icon {
    width: 72px; height: 72px; margin: 0 auto 24px;
    background: rgba(184,149,106,0.08); border: 1px solid rgba(184,149,106,0.2);
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
  }
  .rr-wishlist__empty-icon svg { width: 28px; height: 28px; stroke: #B8956A; fill: none; stroke-width: 1.5; }
  .rr-wishlist__empty-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 30px; font-weight: 300; color: #1A1A1A; margin-bottom: 10px;
  }
  .rr-wishlist__empty-sub { font-size: 13px; color: #8A8A8A; margin-bottom: 28px; line-height: 1.7; }
  .rr-wishlist__empty-btn {
    display: inline-block; background: #1A1A1A; color: #fff;
    padding: 14px 36px; font-size: 11px; font-weight: 500;
    letter-spacing: 2px; text-transform: uppercase;
    text-decoration: none; transition: background 0.3s;
  }
  .rr-wishlist__empty-btn:hover { background: #B8956A; }

  @media (max-width: 1024px) { .rr-wishlist__grid { grid-template-columns: repeat(3,1fr); } }
  @media (max-width: 768px)  {
    .rr-wishlist__hero { padding: 56px 20px 48px; }
    .rr-wishlist__body { padding: 40px 20px 60px; }
    .rr-wishlist__grid { grid-template-columns: 1fr 1fr; gap: 12px; }
  }
  @media (max-width: 480px)  { .rr-wishlist__grid { grid-template-columns: 1fr; } }
</style>

<div class="rr-wishlist">
  <div class="rr-wishlist__hero">
    <div class="rr-wishlist__eyebrow">{{ section.settings.eyebrow }}</div>
    <h1 class="rr-wishlist__title">{{ section.settings.heading }}</h1>
    <p class="rr-wishlist__sub">{{ section.settings.subtext }}</p>
    <div class="rr-wishlist__count-badge" id="rr-wl-count-badge">0 saved items</div>
  </div>

  <div class="rr-wishlist__body">
    <div class="rr-wishlist__body-inner">
      <div class="rr-wishlist__grid" id="rr-wl-grid"></div>
      <div class="rr-wishlist__empty" id="rr-wl-empty" style="display:none">
        <div class="rr-wishlist__empty-icon">
          <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </div>
        <div class="rr-wishlist__empty-title">Your wishlist is empty</div>
        <p class="rr-wishlist__empty-sub">Save your favourite products by clicking the heart icon on any product page.</p>
        <a href="/collections/all" class="rr-wishlist__empty-btn">Explore Products</a>
      </div>
    </div>
  </div>
</div>

<script>
(function(){
  var STORAGE_KEY = 'rr_wishlist';

  function getWishlist() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); }
    catch(e) { return []; }
  }

  function saveWishlist(list) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(list));
  }

  function removeItem(handle) {
    var list = getWishlist().filter(function(p){ return p.handle !== handle; });
    saveWishlist(list);
    render();
  }

  function render() {
    var list  = getWishlist();
    var grid  = document.getElementById('rr-wl-grid');
    var empty = document.getElementById('rr-wl-empty');
    var badge = document.getElementById('rr-wl-count-badge');

    if (!grid) return;

    badge.textContent = list.length + (list.length === 1 ? ' saved item' : ' saved items');

    if (list.length === 0) {
      grid.innerHTML = '';
      empty.style.display = 'block';
      return;
    }
    empty.style.display = 'none';

    grid.innerHTML = list.map(function(p) {
      var sale = p.compare_at_price && p.compare_at_price > p.price;
      return '<div class="rr-wishlist__card">' +
        '<div class="rr-wishlist__card-img">' +
          (p.image ? '<img src="' + p.image + '" alt="' + p.title + '" loading="lazy">' : '') +
          '<button class="rr-wishlist__remove" onclick="window.rrRemoveWishlist(\'' + p.handle + '\')" aria-label="Remove">&#x2715;</button>' +
        '</div>' +
        '<div class="rr-wishlist__card-info">' +
          '<a href="/products/' + p.handle + '" class="rr-wishlist__card-name">' + p.title + '</a>' +
          (p.type ? '<div class="rr-wishlist__card-type">' + p.type + '</div>' : '') +
          '<div class="rr-wishlist__card-bottom">' +
            '<div class="rr-wishlist__card-price">' +
              p.price_formatted +
              (sale ? '<del>' + p.compare_formatted + '</del>' : '') +
            '</div>' +
            '<a href="/products/' + p.handle + '" class="rr-wishlist__add-btn">View Product</a>' +
          '</div>' +
        '</div>' +
      '</div>';
    }).join('');
  }

  window.rrRemoveWishlist = removeItem;

  // Toggle from product pages
  window.rrToggleWishlist = function(product) {
    var list = getWishlist();
    var idx  = list.findIndex(function(p){ return p.handle === product.handle; });
    if (idx === -1) { list.push(product); }
    else            { list.splice(idx, 1); }
    saveWishlist(list);
    return idx === -1; // true = added
  };

  window.rrIsWishlisted = function(handle) {
    return getWishlist().some(function(p){ return p.handle === handle; });
  };

  render();
  window.addEventListener('storage', function(e){ if(e.key === STORAGE_KEY) render(); });
})();
</script>

{% schema %}
{
  "name": "RR Wishlist",
  "tag": "section",
  "class": "section-rr-wishlist",
  "settings": [
    { "type": "text",     "id": "eyebrow",  "label": "Eyebrow",  "default": "My Collection" },
    { "type": "text",     "id": "heading",  "label": "Heading",  "default": "My Wishlist" },
    { "type": "textarea", "id": "subtext",  "label": "Subtext",  "default": "Your saved products, all in one place." }
  ],
  "presets": [{ "name": "RR Wishlist" }]
}
{% endschema %}
