<style>
  .rd-newsletter-section {
    background: {{ section.settings.bg_color | default: '#ffffff' }};
    padding: {{ section.settings.padding_top | default: 80 }}px {{ section.settings.padding_horizontal | default: 48 }}px;
  }
  .rd-newsletter-inner {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
  }
  .rd-newsletter-heading {
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 300;
    color: #1A1A1A;
    margin-bottom: 12px;
    line-height: 1.2;
  }
  .rd-newsletter-heading em {
    font-style: italic;
    color: #B8956A;
  }
  .rd-newsletter-sub {
    font-size: 14px;
    color: #8A8A8A;
    margin-bottom: 32px;
    line-height: 1.6;
  }
  .rd-newsletter-form {
    display: flex;
    gap: 0;
    max-width: 480px;
    margin: 0 auto 12px;
  }
  .rd-newsletter-input {
    flex: 1;
    padding: 16px 24px;
    border: 1px solid #dddddd;
    border-right: none;
    font-size: 13px;
    color: #1A1A1A;
    outline: none;
    background: #F7F3EE;
    transition: border-color 0.3s;
  }
  .rd-newsletter-input:focus { border-color: #B8956A; }
  .rd-newsletter-input::placeholder { color: #8A8A8A; }
  .rd-newsletter-btn {
    padding: 16px 32px;
    background: #1A1A1A;
    color: #ffffff;
    border: 1px solid #1A1A1A;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    white-space: nowrap;
  }
  .rd-newsletter-btn:hover {
    background: #96754A;
    border-color: #96754A;
  }
  .rd-newsletter-disclaimer {
    font-size: 11px;
    color: #aaaaaa;
    line-height: 1.5;
  }
  @media (max-width: 768px) {
    .rd-newsletter-section { padding: 60px 20px; }
    .rd-newsletter-form { flex-direction: column; }
    .rd-newsletter-input { border-right: 1px solid #dddddd; }
  }
</style>

{% form 'customer', id: 'rd-newsletter-form', class: 'rd-newsletter-form-wrapper' %}
  <section class="rd-newsletter-section">
    <div class="rd-newsletter-inner rd-reveal">
      {% if section.settings.heading != blank %}
        <h2 class="rd-newsletter-heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subtext != blank %}
        <p class="rd-newsletter-sub">{{ section.settings.subtext }}</p>
      {% endif %}

      <div class="rd-newsletter-form">
        <input
          type="email"
          name="contact[email]"
          class="rd-newsletter-input"
          placeholder="{{ section.settings.placeholder | default: 'Enter your email' }}"
          aria-label="{{ section.settings.placeholder | default: 'Enter your email' }}"
          required
        >
        <button type="submit" class="rd-newsletter-btn">
          {{ section.settings.button_text | default: 'Subscribe' }}
        </button>
      </div>

      {% if section.settings.disclaimer != blank %}
        <p class="rd-newsletter-disclaimer">{{ section.settings.disclaimer }}</p>
      {% endif %}
    </div>
  </section>
{% endform %}

{% schema %}
{
  "name": "Newsletter CTA",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Join the <em>Radiant</em> Family</p>",
      "info": "Use <em> tags for italic gold text."
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Get exclusive offers, hair care tips, and early access to new launches."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input Placeholder",
      "default": "Enter your email address"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer Text",
      "default": "No spam. Unsubscribe at any time."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Colour",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top/Bottom",
      "min": 40,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding Horizontal",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Newsletter CTA"
    }
  ]
}
{% endschema %}
