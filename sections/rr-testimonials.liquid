<style>
  .rr-testimonials {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_vertical }}px {{ section.settings.padding_horizontal }}px;
    font-family: 'Jost', var(--font-body-family), sans-serif;
  }
  .rr-testimonials__inner { max-width: 1340px; margin: 0 auto; }
  .rr-testimonials .rr-eyebrow { color: #B8956A; }
  .rr-testimonials .rr-heading { color: #FFFFFF; }
  .rr-testimonials .rr-link { color: rgba(255,255,255,0.5); border-color: rgba(255,255,255,0.2); }
  .rr-testimonials .rr-link:hover { color: #D4B896; border-color: #B8956A; }

  .rr-testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px; margin-top: 52px;
  }
  .rr-testimonial-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 20px; padding: 36px 32px;
    transition: all 0.35s; position: relative; overflow: hidden;
  }
  .rr-testimonial-card::before {
    content: '\201C';
    position: absolute; top: -10px; right: 24px;
    font-size: 120px; line-height: 1;
    color: rgba(184,149,106,0.08);
    font-family: 'Cormorant Garamond', Georgia, serif;
    pointer-events: none; user-select: none;
  }
  .rr-testimonial-card:hover {
    transform: translateY(-5px);
    background: rgba(255,255,255,0.06);
    border-color: rgba(184,149,106,0.2);
    box-shadow: 0 20px 50px rgba(0,0,0,0.3);
  }
  .rr-testimonial-stars { color: #B8956A; font-size: 14px; letter-spacing: 2px; margin-bottom: 18px; position: relative; z-index: 1; }
  .rr-testimonial-text {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 18px; font-weight: 400; line-height: 1.6;
    color: rgba(255,255,255,0.82); margin-bottom: 26px; font-style: italic;
    position: relative; z-index: 1;
  }
  .rr-testimonial-author { display: flex; align-items: center; gap: 13px; position: relative; z-index: 1; border-top: 1px solid rgba(255,255,255,0.06); padding-top: 20px; }
  .rr-testimonial-avatar {
    width: 42px; height: 42px; border-radius: 50%;
    background: linear-gradient(135deg, #D4B896, #96754A);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Garamond', Georgia, serif; font-size: 17px; color: #fff; font-weight: 500;
    overflow: hidden; flex-shrink: 0;
  }
  .rr-testimonial-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .rr-testimonial-name { font-size: 13px; font-weight: 600; color: #FFFFFF; }
  .rr-testimonial-verified {
    font-size: 10px; color: rgba(255,255,255,0.4);
    display: flex; align-items: center; gap: 4px;
  }
  .rr-testimonial-verified svg { width: 10px; height: 10px; fill: #4ade80; }

  @media (max-width: 1024px) { .rr-testimonials__grid { grid-template-columns: repeat(2,1fr); } }
  @media (max-width: 768px) {
    .rr-testimonials { padding: {{ section.settings.padding_vertical | divided_by: 1.6 | round }}px 20px; }
    .rr-testimonials__grid { grid-template-columns: 1fr; }
  }
</style>

<section class="rr-testimonials" id="shopify-section-{{ section.id }}">
  <div class="rr-testimonials__inner">

    <div class="rr-section-header">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <div class="rr-eyebrow">{{ section.settings.eyebrow }}</div>
        {%- endif -%}
        <h2 class="rr-heading">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.link_text != blank -%}
        <a href="{{ section.settings.link_url }}" class="rr-link">{{ section.settings.link_text }} →</a>
      {%- endif -%}
    </div>

    <div class="rr-testimonials__grid">
      {%- for block in section.blocks -%}
        <div class="rr-testimonial-card" {{ block.shopify_attributes }}>
          <div class="rr-testimonial-stars">
            {%- for i in (1..block.settings.rating) -%}★{%- endfor -%}
          </div>
          <p class="rr-testimonial-text">"{{ block.settings.review_text }}"</p>
          <div class="rr-testimonial-author">
            <div class="rr-testimonial-avatar">
              {%- if block.settings.avatar != blank -%}
                {{ block.settings.avatar | image_url: width: 84 | image_tag: loading: 'lazy' }}
              {%- else -%}
                {{ block.settings.author_name | slice: 0 | upcase }}
              {%- endif -%}
            </div>
            <div>
              <div class="rr-testimonial-name">{{ block.settings.author_name }}</div>
              {%- if block.settings.verified -%}
                <div class="rr-testimonial-verified">
                  <svg viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/></svg>
                  Verified Purchase
                </div>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "RR Testimonials",
  "tag": "section",
  "class": "section-rr-testimonials",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Real Results"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "Read All Reviews"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Padding top/bottom",
      "min": 40, "max": 160, "step": 8,
      "default": 104, "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding horizontal",
      "min": 0, "max": 80, "step": 4,
      "default": 52, "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "range", "id": "rating", "label": "Stars", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "review_text", "label": "Review", "default": "This product has transformed my hair. Highly recommend!" },
        { "type": "text", "id": "author_name", "label": "Name", "default": "Happy Customer" },
        { "type": "image_picker", "id": "avatar", "label": "Avatar photo" },
        { "type": "checkbox", "id": "verified", "label": "Verified badge", "default": true }
      ]
    }
  ],
  "presets": [
    {
      "name": "RR Testimonials",
      "blocks": [
        { "type": "testimonial", "settings": { "rating": 5, "review_text": "My hair has never felt this soft and healthy. After just two weeks, I noticed less breakage and more shine. This is the real deal.", "author_name": "Sarah M.", "verified": true } },
        { "type": "testimonial", "settings": { "rating": 5, "review_text": "I was skeptical at first but the results are undeniable. My hair is noticeably fuller and stronger. Worth every penny.", "author_name": "Jessica L.", "verified": true } },
        { "type": "testimonial", "settings": { "rating": 5, "review_text": "Finally a shampoo that actually delivers on its promises. The rosemary scent is amazing and my scalp feels so healthy.", "author_name": "Priya K.", "verified": true } }
      ]
    }
  ]
}
{% endschema %}
