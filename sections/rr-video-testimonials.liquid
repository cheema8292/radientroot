<style>
  .rr-video-t {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_vertical }}px {{ section.settings.padding_horizontal }}px;
    position: relative; overflow: hidden;
    font-family: 'Jost', var(--font-body-family), sans-serif;
  }
  .rr-video-t::before {
    content: '';
    position: absolute; bottom: -100px; left: -100px;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(184,149,106,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .rr-video-t__inner { max-width: 1340px; margin: 0 auto; position: relative; z-index: 1; }
  .rr-video-t__header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 60px; gap: 20px; }

  .rr-video-t__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 20px; align-items: start;
  }

  /* Main card */
  .rr-video-main {
    position: relative; border-radius: 24px; overflow: hidden;
    cursor: pointer; aspect-ratio: 9/16; max-height: 520px;
    background: #1a140d;
  }
  .rr-video-main__bg {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .rr-video-main__bg img { width: 100%; height: 100%; object-fit: cover; }
  .rr-video-main__bg-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(160deg, #2a2520, #1a1510);
    display: flex; align-items: center; justify-content: center;
    font-size: 72px; opacity: 0.12;
  }
  .rr-video-main__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(0deg, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.1) 55%, rgba(0,0,0,0) 100%);
  }
  .rr-video-play {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 70px; height: 70px;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(12px);
    border: 1.5px solid rgba(255,255,255,0.25);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.3s; z-index: 2;
  }
  .rr-video-play svg { width: 26px; height: 26px; color: #fff; margin-left: 4px; }
  .rr-video-main:hover .rr-video-play { background: #B8956A; border-color: #B8956A; transform: translate(-50%, -50%) scale(1.1); }
  .rr-video-main__duration {
    position: absolute; top: 16px; right: 16px;
    background: rgba(0,0,0,0.5); backdrop-filter: blur(8px);
    color: #fff; font-size: 11px; font-weight: 500;
    padding: 4px 10px; border-radius: 8px; z-index: 2;
  }
  .rr-video-main__info {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 28px; z-index: 2;
  }
  .rr-video-main__stars { color: #B8956A; font-size: 12px; letter-spacing: 2px; margin-bottom: 10px; }
  .rr-video-main__quote {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 20px; font-weight: 400; font-style: italic;
    color: #fff; line-height: 1.4; margin-bottom: 16px;
  }
  .rr-video-main__author { display: flex; align-items: center; gap: 12px; }
  .rr-video-avatar {
    width: 40px; height: 40px; border-radius: 50%;
    border: 2px solid #B8956A;
    background: linear-gradient(135deg, #D4B896, #96754A);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Garamond', Georgia, serif; font-size: 16px; color: #fff;
    overflow: hidden; flex-shrink: 0;
  }
  .rr-video-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .rr-video-author-name { font-size: 13px; font-weight: 500; color: #fff; }
  .rr-video-author-sub { font-size: 10.5px; color: rgba(255,255,255,0.5); display: flex; align-items: center; gap: 5px; }
  .rr-video-author-sub svg { width: 10px; height: 10px; }

  /* Video badge */
  .rr-video-badge {
    position: absolute; top: 16px; left: 16px; z-index: 2;
    background: #B8956A; color: #fff;
    font-size: 9px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase;
    padding: 4px 10px; border-radius: 20px;
    display: flex; align-items: center; gap: 5px;
  }
  .rr-video-badge svg { width: 9px; height: 9px; fill: #fff; }

  /* Side cards */
  .rr-video-side { display: flex; flex-direction: column; gap: 16px; }
  .rr-video-card {
    background: #fff; border-radius: 20px; overflow: hidden;
    border: 1px solid rgba(0,0,0,0.05);
    transition: all 0.35s; cursor: pointer;
  }
  .rr-video-card:hover { transform: translateY(-4px); box-shadow: 0 32px 80px rgba(0,0,0,0.13); border-color: rgba(184,149,106,0.15); }
  .rr-video-card__top {
    position: relative; height: 180px;
    background: linear-gradient(160deg, #2a2520, #1a1510);
    overflow: hidden; display: flex; align-items: center; justify-content: center;
  }
  .rr-video-card__top img { width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; }
  .rr-video-card__placeholder { font-size: 60px; opacity: 0.1; }
  .rr-video-card__overlay { position: absolute; inset: 0; background: linear-gradient(0deg, rgba(0,0,0,0.5) 0%, transparent 60%); }
  .rr-video-card__play {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 48px; height: 48px;
    background: rgba(255,255,255,0.14); backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.25); border-radius: 50%;
    display: flex; align-items: center; justify-content: center; transition: all 0.3s;
  }
  .rr-video-card__play svg { width: 18px; height: 18px; color: #fff; margin-left: 3px; }
  .rr-video-card:hover .rr-video-card__play { background: #B8956A; border-color: #B8956A; }
  .rr-video-card__duration {
    position: absolute; top: 12px; right: 12px;
    background: rgba(0,0,0,0.5); color: #fff;
    font-size: 10px; padding: 3px 8px; border-radius: 6px;
  }
  .rr-video-card__body { padding: 20px 22px; }
  .rr-video-card__stars { color: #B8956A; font-size: 11px; letter-spacing: 1.5px; margin-bottom: 8px; }
  .rr-video-card__text {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 16px; font-style: italic; font-weight: 400;
    color: #2D2D2D; line-height: 1.45; margin-bottom: 14px;
  }
  .rr-video-card__author { display: flex; align-items: center; gap: 10px; }
  .rr-video-card__avatar {
    width: 32px; height: 32px; border-radius: 50%;
    background: linear-gradient(135deg, #D4B896, #96754A);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Garamond', Georgia, serif; font-size: 13px; color: #fff;
    overflow: hidden; flex-shrink: 0;
  }
  .rr-video-card__avatar img { width: 100%; height: 100%; object-fit: cover; }
  .rr-video-card__name { font-size: 12px; font-weight: 600; color: #1A1A1A; }
  .rr-video-card__verified { font-size: 10px; color: #8A8A8A; display: flex; align-items: center; gap: 4px; }
  .rr-video-card__verified svg { width: 10px; height: 10px; color: #4ade80; }

  /* Stats bar */
  .rr-video-stats {
    display: flex; align-items: center; justify-content: center;
    gap: 64px; margin-top: 56px; padding: 40px 60px;
    background: #fff; border-radius: 20px;
    border: 1px solid rgba(184,149,106,0.1);
  }
  .rr-stat { text-align: center; }
  .rr-stat__number {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 40px; font-weight: 300; color: #1A1A1A; letter-spacing: -1px; margin-bottom: 4px;
  }
  .rr-stat__label { font-size: 11px; color: #8A8A8A; letter-spacing: 1.5px; text-transform: uppercase; }
  .rr-stat__divider { width: 1px; height: 48px; background: rgba(0,0,0,0.06); }

  /* Video lightbox modal */
  .rr-video-modal {
    display: none;
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,0.88);
    align-items: center; justify-content: center;
    padding: 20px;
  }
  .rr-video-modal.is-open { display: flex; }
  .rr-video-modal__inner {
    position: relative;
    width: 100%; max-width: 860px;
    aspect-ratio: 9/16;
    max-height: 80vh;
    background: #000;
    border-radius: 16px; overflow: hidden;
  }
  .rr-video-modal__inner.is-landscape { aspect-ratio: 16/9; max-height: 80vh; }
  .rr-video-modal__iframe {
    width: 100%; height: 100%; border: none;
  }
  .rr-video-modal__close {
    position: absolute; top: -48px; right: 0;
    width: 40px; height: 40px;
    background: rgba(255,255,255,0.12); border: none;
    border-radius: 50%; cursor: pointer; color: #fff;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s; font-size: 22px; line-height: 1;
  }
  .rr-video-modal__close:hover { background: #B8956A; }

  @media (max-width: 1200px) {
    .rr-video-t__grid { grid-template-columns: 1fr 1fr; }
    .rr-video-side:last-child { display: none; }
  }
  @media (max-width: 768px) {
    .rr-video-t { padding: 60px 20px; }
    .rr-video-t__grid { grid-template-columns: 1fr; }
    .rr-video-t__header { flex-direction: column; align-items: flex-start; }
    .rr-video-stats { gap: 32px; padding: 30px 20px; flex-wrap: wrap; }
    .rr-stat__divider { width: 60px; height: 1px; }
    .rr-video-modal__inner { aspect-ratio: 9/16; max-height: 85vh; }
  }
</style>

<section class="rr-video-t" id="shopify-section-{{ section.id }}">
  <div class="rr-video-t__inner">

    <div class="rr-video-t__header">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <div class="rr-eyebrow">{{ section.settings.eyebrow }}</div>
        {%- endif -%}
        <h2 class="rr-heading">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.link_text != blank -%}
        <a href="{{ section.settings.link_url }}" class="rr-link">{{ section.settings.link_text }} →</a>
      {%- endif -%}
    </div>

    {%- assign main_block = section.blocks | where: "type", "main_video" | first -%}
    {%- assign side_blocks = section.blocks | where: "type", "side_video" -%}

    <div class="rr-video-t__grid">

      {%- if main_block -%}
        {%- assign main_embed = '' -%}
        {%- if main_block.settings.video_url != blank -%}
          {%- if main_block.settings.video_url.type == 'youtube' -%}
            {%- assign main_embed = 'https://www.youtube.com/embed/' | append: main_block.settings.video_url.id | append: '?autoplay=1&rel=0' -%}
          {%- elsif main_block.settings.video_url.type == 'vimeo' -%}
            {%- assign main_embed = 'https://player.vimeo.com/video/' | append: main_block.settings.video_url.id | append: '?autoplay=1' -%}
          {%- endif -%}
        {%- endif -%}
        <div class="rr-video-main" {% if main_embed != blank %}data-video="{{ main_embed }}" data-video-orient="portrait"{% endif %} {{ main_block.shopify_attributes }}>
          <div class="rr-video-main__bg">
            {%- if main_block.settings.thumbnail != blank -%}
              {{ main_block.settings.thumbnail | image_url: width: 600 | image_tag: loading: 'lazy' }}
            {%- else -%}
              <div class="rr-video-main__bg-placeholder">▶</div>
            {%- endif -%}
          </div>
          <div class="rr-video-main__overlay"></div>
          {%- if main_embed != blank -%}
            <div class="rr-video-badge">
              <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              Watch Video
            </div>
          {%- endif -%}
          <div class="rr-video-play">
            <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          </div>
          {%- if main_block.settings.duration != blank -%}
            <div class="rr-video-main__duration">{{ main_block.settings.duration }}</div>
          {%- endif -%}
          <div class="rr-video-main__info">
            <div class="rr-video-main__stars">★★★★★</div>
            <div class="rr-video-main__quote">"{{ main_block.settings.quote }}"</div>
            <div class="rr-video-main__author">
              <div class="rr-video-avatar">
                {%- if main_block.settings.avatar != blank -%}
                  {{ main_block.settings.avatar | image_url: width: 80 | image_tag: loading: 'lazy' }}
                {%- else -%}
                  {{ main_block.settings.author_name | slice: 0 | upcase }}
                {%- endif -%}
              </div>
              <div>
                <div class="rr-video-author-name">{{ main_block.settings.author_name }}</div>
                <div class="rr-video-author-sub">
                  <svg viewBox="0 0 24 24" fill="#4ade80"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01" stroke="#4ade80" fill="none" stroke-width="2.5"/></svg>
                  Verified Purchase
                </div>
              </div>
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- if side_blocks.size > 0 -%}
        <div class="rr-video-side">
          {%- for block in side_blocks limit: 2 -%}
            {%- assign side_embed = '' -%}
            {%- if block.settings.video_url != blank -%}
              {%- if block.settings.video_url.type == 'youtube' -%}
                {%- assign side_embed = 'https://www.youtube.com/embed/' | append: block.settings.video_url.id | append: '?autoplay=1&rel=0' -%}
              {%- elsif block.settings.video_url.type == 'vimeo' -%}
                {%- assign side_embed = 'https://player.vimeo.com/video/' | append: block.settings.video_url.id | append: '?autoplay=1' -%}
              {%- endif -%}
            {%- endif -%}
            <div class="rr-video-card" {% if side_embed != blank %}data-video="{{ side_embed }}" data-video-orient="portrait"{% endif %} {{ block.shopify_attributes }}>
              <div class="rr-video-card__top">
                {%- if block.settings.thumbnail != blank -%}
                  {{ block.settings.thumbnail | image_url: width: 400 | image_tag: loading: 'lazy' }}
                {%- else -%}
                  <div class="rr-video-card__placeholder">▶</div>
                {%- endif -%}
                <div class="rr-video-card__overlay"></div>
                <div class="rr-video-card__play">
                  <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                </div>
                {%- if block.settings.duration != blank -%}
                  <div class="rr-video-card__duration">{{ block.settings.duration }}</div>
                {%- endif -%}
              </div>
              <div class="rr-video-card__body">
                <div class="rr-video-card__stars">★★★★★</div>
                <div class="rr-video-card__text">"{{ block.settings.quote }}"</div>
                <div class="rr-video-card__author">
                  <div class="rr-video-card__avatar">
                    {%- if block.settings.avatar != blank -%}
                      {{ block.settings.avatar | image_url: width: 64 | image_tag: loading: 'lazy' }}
                    {%- else -%}
                      {{ block.settings.author_name | slice: 0 | upcase }}
                    {%- endif -%}
                  </div>
                  <div>
                    <div class="rr-video-card__name">{{ block.settings.author_name }}</div>
                    {%- if block.settings.verified -%}
                      <div class="rr-video-card__verified">
                        <svg viewBox="0 0 24 24" fill="#4ade80"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01" stroke="#4ade80" fill="none" stroke-width="2.5"/></svg>
                        Verified
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>

        {%- if side_blocks.size > 2 -%}
          <div class="rr-video-side">
            {%- for block in side_blocks offset: 2 limit: 2 -%}
              {%- assign side_embed2 = '' -%}
              {%- if block.settings.video_url != blank -%}
                {%- if block.settings.video_url.type == 'youtube' -%}
                  {%- assign side_embed2 = 'https://www.youtube.com/embed/' | append: block.settings.video_url.id | append: '?autoplay=1&rel=0' -%}
                {%- elsif block.settings.video_url.type == 'vimeo' -%}
                  {%- assign side_embed2 = 'https://player.vimeo.com/video/' | append: block.settings.video_url.id | append: '?autoplay=1' -%}
                {%- endif -%}
              {%- endif -%}
              <div class="rr-video-card" {% if side_embed2 != blank %}data-video="{{ side_embed2 }}" data-video-orient="portrait"{% endif %} {{ block.shopify_attributes }}>
                <div class="rr-video-card__top">
                  {%- if block.settings.thumbnail != blank -%}
                    {{ block.settings.thumbnail | image_url: width: 400 | image_tag: loading: 'lazy' }}
                  {%- else -%}
                    <div class="rr-video-card__placeholder">▶</div>
                  {%- endif -%}
                  <div class="rr-video-card__overlay"></div>
                  <div class="rr-video-card__play">
                    <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                  </div>
                  {%- if block.settings.duration != blank -%}
                    <div class="rr-video-card__duration">{{ block.settings.duration }}</div>
                  {%- endif -%}
                </div>
                <div class="rr-video-card__body">
                  <div class="rr-video-card__stars">★★★★★</div>
                  <div class="rr-video-card__text">"{{ block.settings.quote }}"</div>
                  <div class="rr-video-card__author">
                    <div class="rr-video-card__avatar">{{ block.settings.author_name | slice: 0 | upcase }}</div>
                    <div><div class="rr-video-card__name">{{ block.settings.author_name }}</div></div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_stats -%}
      <div class="rr-video-stats">
        {%- if section.settings.stat1_number != blank -%}
          <div class="rr-stat">
            <div class="rr-stat__number">{{ section.settings.stat1_number }}</div>
            <div class="rr-stat__label">{{ section.settings.stat1_label }}</div>
          </div>
          <div class="rr-stat__divider"></div>
        {%- endif -%}
        {%- if section.settings.stat2_number != blank -%}
          <div class="rr-stat">
            <div class="rr-stat__number">{{ section.settings.stat2_number }}</div>
            <div class="rr-stat__label">{{ section.settings.stat2_label }}</div>
          </div>
          <div class="rr-stat__divider"></div>
        {%- endif -%}
        {%- if section.settings.stat3_number != blank -%}
          <div class="rr-stat">
            <div class="rr-stat__number">{{ section.settings.stat3_number }}</div>
            <div class="rr-stat__label">{{ section.settings.stat3_label }}</div>
          </div>
          <div class="rr-stat__divider"></div>
        {%- endif -%}
        {%- if section.settings.stat4_number != blank -%}
          <div class="rr-stat">
            <div class="rr-stat__number">{{ section.settings.stat4_number }}</div>
            <div class="rr-stat__label">{{ section.settings.stat4_label }}</div>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

<!-- Video lightbox modal (shared for all cards) -->
<div class="rr-video-modal" id="rr-video-modal-{{ section.id }}" role="dialog" aria-modal="true">
  <div class="rr-video-modal__inner" id="rr-video-modal-inner-{{ section.id }}">
    <button class="rr-video-modal__close" id="rr-video-modal-close-{{ section.id }}" aria-label="Close video">&#x2715;</button>
    <iframe class="rr-video-modal__iframe" id="rr-video-modal-iframe-{{ section.id }}"
      src="" allow="autoplay; fullscreen" allowfullscreen></iframe>
  </div>
</div>

<script>
(function () {
  var sectionId = {{ section.id | json }};
  var modal     = document.getElementById('rr-video-modal-' + sectionId);
  var inner     = document.getElementById('rr-video-modal-inner-' + sectionId);
  var iframe    = document.getElementById('rr-video-modal-iframe-' + sectionId);
  var closeBtn  = document.getElementById('rr-video-modal-close-' + sectionId);
  var section   = document.getElementById('shopify-section-' + sectionId);

  if (!modal || !section) return;

  function openModal(url, orient) {
    iframe.src = url;
    inner.classList.toggle('is-landscape', orient !== 'portrait');
    modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }
  function closeModal() {
    modal.classList.remove('is-open');
    iframe.src = '';
    document.body.style.overflow = '';
  }

  section.querySelectorAll('[data-video]').forEach(function (el) {
    el.addEventListener('click', function () {
      var url = el.getAttribute('data-video');
      var orient = el.getAttribute('data-video-orient') || 'portrait';
      if (url) openModal(url, orient);
    });
  });

  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', function (e) {
    if (e.target === modal) closeModal();
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeModal();
  });
})();
</script>

{% schema %}
{
  "name": "RR Video Testimonials",
  "tag": "section",
  "class": "section-rr-video-t",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Real Stories" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Hear It From Our Customers" },
    { "type": "text", "id": "link_text", "label": "Link text", "default": "View All Reviews" },
    { "type": "url",  "id": "link_url",  "label": "Link URL" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#F7F3EE" },
    { "type": "range", "id": "padding_vertical",   "label": "Padding top/bottom", "min": 40, "max": 160, "step": 8,  "default": 112, "unit": "px" },
    { "type": "range", "id": "padding_horizontal",  "label": "Padding horizontal", "min": 0,  "max": 80,  "step": 4,  "default": 52,  "unit": "px" },
    { "type": "header", "content": "Stats Bar" },
    { "type": "checkbox", "id": "show_stats", "label": "Show stats bar", "default": true },
    { "type": "text", "id": "stat1_number", "label": "Stat 1 number", "default": "137K+" },
    { "type": "text", "id": "stat1_label",  "label": "Stat 1 label",  "default": "Happy Customers" },
    { "type": "text", "id": "stat2_number", "label": "Stat 2 number", "default": "4.8 Stars" },
