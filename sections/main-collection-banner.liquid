{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}

<style>
  .rd-collection-hero {
    background: {{ section.settings.bg_color | default: '#111111' }};
    position: relative;
    overflow: hidden;
    padding: {{ section.settings.padding_top | default: 80 }}px {{ section.settings.padding_horizontal | default: 48 }}px;
    text-align: center;
  }
  .rd-collection-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center top, rgba(184,149,106,0.12) 0%, transparent 60%);
    pointer-events: none;
  }
  .rd-collection-hero-deco {
    position: absolute;
    border: 1px solid rgba(184,149,106,0.06);
    pointer-events: none;
    border-radius: 50%;
  }
  .rd-collection-hero-deco-1 { width: 300px; height: 300px; top: -80px; right: -60px; }
  .rd-collection-hero-deco-2 { width: 200px; height: 200px; bottom: -40px; left: -40px; }
  .rd-collection-hero-inner {
    position: relative;
    z-index: 2;
    max-width: 680px;
    margin: 0 auto;
  }
  .rd-collection-breadcrumb {
    font-size: 11px;
    color: rgba(255,255,255,0.35);
    letter-spacing: 1px;
    margin-bottom: 20px;
    text-transform: uppercase;
  }
  .rd-collection-breadcrumb a {
    color: rgba(255,255,255,0.35);
    text-decoration: none;
    transition: color 0.3s;
  }
  .rd-collection-breadcrumb a:hover { color: #D4B896; }
  .rd-collection-breadcrumb span { color: #D4B896; }
  .rd-collection-hero-title {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 300;
    color: #ffffff;
    margin-bottom: 14px;
    line-height: 1.15;
  }
  .rd-collection-hero-title em {
    font-style: italic;
    color: #D4B896;
  }
  .rd-collection-hero-desc {
    font-size: 14px;
    color: rgba(255,255,255,0.45);
    line-height: 1.7;
    max-width: 480px;
    margin: 0 auto 28px;
  }
  .rd-collection-hero-count {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #D4B896;
    border: 1px solid rgba(184,149,106,0.25);
    border-radius: 40px;
    padding: 6px 18px;
  }
  .rd-collection-hero-count-dot {
    width: 5px;
    height: 5px;
    background: #B8956A;
    border-radius: 50%;
    flex-shrink: 0;
  }
  @media (max-width: 768px) {
    .rd-collection-hero {
      padding: {{ section.settings.padding_top_mobile | default: 48 }}px 20px;
    }
  }
</style>

<div class="rd-collection-hero">
  <div class="rd-collection-hero-deco rd-collection-hero-deco-1"></div>
  <div class="rd-collection-hero-deco rd-collection-hero-deco-2"></div>
  <div class="rd-collection-hero-inner">

    {% if section.settings.show_breadcrumb %}
      <div class="rd-collection-breadcrumb">
        <a href="{{ routes.root_url }}">{{ 'general.breadcrumbs.home' | t | default: 'Home' }}</a>
        &nbsp;/&nbsp;
        <span>{{ collection.title | default: section.settings.title }}</span>
      </div>
    {% endif %}

    <h1 class="rd-collection-hero-title">
      {% if section.settings.title_override != blank %}
        {{ section.settings.title_override }}
      {% else %}
        {% assign title_words = collection.title | default: 'Products' | split: ' ' %}
        {% if title_words.size > 1 %}
          {% for word in title_words %}
            {% if forloop.last %}<em>{{ word }}</em>{% else %}{{ word }} {% endif %}
          {% endfor %}
        {% else %}
          {{ collection.title | default: 'Products' }}
        {% endif %}
      {% endif %}
    </h1>

    {% if section.settings.show_description %}
      {% if section.settings.description_override != blank %}
        <p class="rd-collection-hero-desc">{{ section.settings.description_override }}</p>
      {% elsif collection.description != blank %}
        <p class="rd-collection-hero-desc">{{ collection.description | strip_html | truncatewords: 40 }}</p>
      {% endif %}
    {% endif %}

    {% if section.settings.show_product_count %}
      <div class="rd-collection-hero-count">
        <span class="rd-collection-hero-count-dot"></span>
        {{ collection.products_count | default: 0 }} {{ 'collections.general.items_with_count' | t: count: collection.products_count | default: 'Products' }}
      </div>
    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "Collection Banner",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title_override",
      "label": "Title Override",
      "info": "Leave blank to use the collection title. The last word will be italicised in gold."
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show Description",
      "default": true
    },
    {
      "type": "textarea",
      "id": "description_override",
      "label": "Description Override",
      "info": "Leave blank to use the collection description."
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show Breadcrumb",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show Product Count",
      "default": true
    },
    {
      "type": "header",
      "content": "Design"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Colour",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (desktop)",
      "min": 20,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding Horizontal (desktop)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (mobile)",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Collection Banner"
    }
  ]
}
{% endschema %}
