<style>
  .rr-hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    background: {{ section.settings.bg_color }};
    overflow: hidden;
    font-family: 'Jost', var(--font-body-family), sans-serif;
  }
  .rr-hero::before {
    content: '';
    position: absolute;
    top: -30%; right: -10%;
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(184,149,106,0.07) 0%, transparent 70%);
    pointer-events: none;
  }
  .rr-hero__inner {
    max-width: 1340px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 0 52px;
    gap: 48px;
    width: 100%;
  }
  .rr-hero__content { position: relative; z-index: 2; }
  .rr-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border: 1px solid #D4B896;
    border-radius: 40px;
    padding: 7px 20px;
    margin-bottom: 30px;
    background: rgba(184,149,106,0.04);
  }
  .rr-hero__badge-stars { color: #B8956A; font-size: 12px; letter-spacing: 2px; }
  .rr-hero__badge-text { font-size: 11px; color: #8A8A8A; font-weight: 400; letter-spacing: 0.5px; }
  .rr-hero h1 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(42px, 5.2vw, 68px);
    font-weight: 300;
    line-height: 1.08;
    color: {{ section.settings.heading_color }};
    margin-bottom: 12px;
  }
  .rr-hero h1 em { font-style: italic; color: #B8956A; font-weight: 400; }
  .rr-hero__sub {
    font-size: 15px;
    line-height: 1.75;
    color: #555555;
    max-width: 410px;
    margin-bottom: 38px;
    font-weight: 300;
  }
  .rr-hero__actions { display: flex; align-items: center; gap: 22px; }

  .rr-btn-primary {
    background: #1A1A1A; color: #FFFFFF;
    padding: 17px 44px;
    border: 1.5px solid #1A1A1A;
    font-family: 'Jost', var(--font-body-family), sans-serif;
    font-size: 11.5px; font-weight: 500;
    letter-spacing: 2.5px; text-transform: uppercase;
    text-decoration: none; cursor: pointer;
    transition: all 0.4s; position: relative; overflow: hidden;
    display: inline-block;
  }
  .rr-btn-primary::after {
    content: ''; position: absolute; inset: 0;
    background: #B8956A; transform: translateX(-101%);
    transition: transform 0.4s ease; z-index: 0;
  }
  .rr-btn-primary span { position: relative; z-index: 1; }
  .rr-btn-primary:hover::after { transform: translateX(0); }
  .rr-btn-primary:hover { border-color: #B8956A; color: #fff; }

  .rr-btn-secondary {
    font-size: 12.5px; color: #555555; text-decoration: none;
    font-weight: 400; letter-spacing: 0.5px;
    border-bottom: 1px solid #D4B896; padding-bottom: 2px;
    transition: all 0.3s;
  }
  .rr-btn-secondary:hover { color: #B8956A; border-color: #B8956A; }

  .rr-hero__visual {
    position: relative; height: 92vh;
    display: flex; align-items: center; justify-content: center;
  }
  .rr-hero__img-wrapper {
    position: relative; width: 100%; height: 82%;
    background: linear-gradient(160deg, #F7F3EE 0%, #EDE7DF 100%);
    border-radius: 0 0 0 90px;
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
  }
  .rr-hero__img-wrapper img {
    width: 100%; height: 100%; object-fit: cover;
  }
  .rr-hero__img-placeholder {
    width: 240px; height: 460px;
    background: linear-gradient(180deg, #2a2a2a 0%, #1a1a1a 100%);
    border-radius: 12px 12px 6px 6px;
    position: relative;
    box-shadow: 0 40px 80px rgba(0,0,0,0.18);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
  }
  .rr-hero__float-badge {
    position: absolute; bottom: 12%; left: -24px;
    background: #FFFFFF; border-radius: 14px;
    padding: 16px 22px; box-shadow: 0 24px 60px rgba(0,0,0,0.09);
    display: flex; align-items: center; gap: 12px;
    animation: rr-floatY 3s ease-in-out infinite;
  }
  .rr-hero__float-icon {
    width: 38px; height: 38px;
    background: rgba(184,149,106,0.1); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .rr-hero__float-icon svg { width: 16px; height: 16px; color: #B8956A; stroke: #B8956A; }
  .rr-hero__float-label { font-size: 11.5px; font-weight: 500; color: #1A1A1A; }
  .rr-hero__float-sub { font-size: 10px; color: #8A8A8A; }

  @keyframes rr-floatY {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  @media (max-width: 1024px) {
    .rr-hero__inner { grid-template-columns: 1fr; }
    .rr-hero__visual { display: none; }
  }
  @media (max-width: 768px) {
    .rr-hero__inner { padding: 60px 20px; }
  }
</style>

<section class="rr-hero" id="shopify-section-{{ section.id }}">
  <div class="rr-hero__inner">

    <div class="rr-hero__content">
      {%- if section.settings.badge_text != blank -%}
        <div class="rr-hero__badge">
          <span class="rr-hero__badge-stars">★★★★★</span>
          <span class="rr-hero__badge-text">{{ section.settings.badge_text }}</span>
        </div>
      {%- endif -%}

      <h1>
        {{ section.settings.heading }}
        {%- if section.settings.heading_italic != blank -%}
          <br><em>{{ section.settings.heading_italic }}</em>
        {%- endif -%}
      </h1>

      {%- if section.settings.subtext != blank -%}
        <p class="rr-hero__sub">{{ section.settings.subtext }}</p>
      {%- endif -%}

      <div class="rr-hero__actions">
        {%- if section.settings.btn1_text != blank -%}
          <a href="{{ section.settings.btn1_link }}" class="rr-btn-primary">
            <span>{{ section.settings.btn1_text }}</span>
          </a>
        {%- endif -%}
        {%- if section.settings.btn2_text != blank -%}
          <a href="{{ section.settings.btn2_link }}" class="rr-btn-secondary">{{ section.settings.btn2_text }}</a>
        {%- endif -%}
      </div>
    </div>

    <div class="rr-hero__visual">
      <div class="rr-hero__img-wrapper">
        {%- if section.settings.hero_image != blank -%}
          {{
            section.settings.hero_image
            | image_url: width: 900
            | image_tag:
              loading: 'eager',
              widths: '400,600,900',
              sizes: '(max-width: 1024px) 100vw, 50vw',
              alt: section.settings.heading
          }}
        {%- else -%}
          <div class="rr-hero__img-placeholder"></div>
        {%- endif -%}

        {%- if section.settings.float_badge_title != blank -%}
          <div class="rr-hero__float-badge">
            <div class="rr-hero__float-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            </div>
            <div>
              <div class="rr-hero__float-label">{{ section.settings.float_badge_title }}</div>
              <div class="rr-hero__float-sub">{{ section.settings.float_badge_sub }}</div>
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "RR Hero",
  "tag": "section",
  "class": "section-rr-hero",
  "settings": [
    {
      "type": "header",
      "content": "Badge"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "4.8/5 based on 137,135 reviews"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (first line)",
      "default": "Premium Hair Care,"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading italic line",
      "default": "Naturally Crafted."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Rosemary-infused formulas that nourish, strengthen, and transform your hair from root to tip. No sulfates. No parabens. Just results."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Primary button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "btn1_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "btn2_text",
      "label": "Secondary button text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "btn2_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Hero Image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Product image"
    },
    {
      "type": "header",
      "content": "Floating Badge"
    },
    {
      "type": "text",
      "id": "float_badge_title",
      "label": "Badge title",
      "default": "Dermatologist Tested"
    },
    {
      "type": "text",
      "id": "float_badge_sub",
      "label": "Badge subtitle",
      "default": "Safe for all hair types"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1A1A1A"
    }
  ],
  "presets": [
    {
      "name": "RR Hero"
    }
  ]
}
{% endschema %}
