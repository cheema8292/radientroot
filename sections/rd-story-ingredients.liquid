<style>
  .rd-story-section {
    background: {{ section.settings.bg_color | default: '#111111' }};
    padding: {{ section.settings.padding_top | default: 100 }}px {{ section.settings.padding_horizontal | default: 48 }}px;
    position: relative;
    overflow: hidden;
  }
  .rd-story-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .rd-story-img-box {
    width: 100%;
    aspect-ratio: 3/4;
    background: linear-gradient(160deg, #2a2520, #1a1510);
    border-radius: 20px;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rd-story-img-box img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 20px;
  }
  .rd-story-img-placeholder {
    font-size: 120px;
    opacity: 0.15;
  }
  .rd-story-badge-overlay {
    position: absolute;
    bottom: 24px;
    left: 24px;
    right: 24px;
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .rd-story-badge-num {
    font-size: 36px;
    font-weight: 300;
    color: #D4B896;
    line-height: 1;
  }
  .rd-story-badge-text {
    font-size: 12px;
    color: rgba(255,255,255,0.6);
    line-height: 1.5;
  }
  .rd-story-eyebrow {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #B8956A;
    margin-bottom: 12px;
  }
  .rd-story-heading {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 300;
    color: #ffffff;
    line-height: 1.15;
    margin-bottom: 24px;
  }
  .rd-story-heading em {
    font-style: italic;
    color: #D4B896;
  }
  .rd-story-text {
    font-size: 14px;
    line-height: 1.9;
    color: rgba(255,255,255,0.5);
    margin-bottom: 32px;
    max-width: 460px;
  }
  .rd-story-ingredients {
    display: flex;
    gap: 16px;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }
  .rd-story-ingredient {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 18px 22px;
    text-align: center;
    transition: all 0.3s;
    flex: 1;
    min-width: 90px;
  }
  .rd-story-ingredient:hover {
    border-color: rgba(184,149,106,0.3);
    background: rgba(184,149,106,0.05);
  }
  .rd-story-ingredient-emoji {
    font-size: 28px;
    margin-bottom: 8px;
    display: block;
  }
  .rd-story-ingredient-name {
    font-size: 11px;
    font-weight: 500;
    color: #ffffff;
    letter-spacing: 0.5px;
    display: block;
  }
  .rd-story-ingredient-desc {
    font-size: 10px;
    color: rgba(255,255,255,0.4);
    margin-top: 2px;
    display: block;
  }
  .rd-story-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border: 1px solid #B8956A;
    color: #D4B896;
    padding: 14px 32px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.3s;
  }
  .rd-story-btn:hover {
    background: #B8956A;
    color: #ffffff;
  }
  .rd-story-btn svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
  @media (max-width: 1024px) {
    .rd-story-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .rd-story-visual { display: none; }
  }
  @media (max-width: 768px) {
    .rd-story-section { padding: 60px 20px; }
  }
</style>

<section class="rd-story-section">
  <div class="rd-story-inner">

    {% if section.settings.show_image %}
      <div class="rd-story-visual rd-reveal">
        <div class="rd-story-img-box">
          {% if section.settings.image %}
            <img src="{{ section.settings.image | img_url: '800x' }}" alt="{{ section.settings.image_alt | escape | default: section.settings.heading }}" loading="lazy">
          {% else %}
            <span class="rd-story-img-placeholder">🌿</span>
          {% endif %}
          <div class="rd-story-badge-overlay">
            <div class="rd-story-badge-num">{{ section.settings.badge_number }}</div>
            <div class="rd-story-badge-text">{{ section.settings.badge_text }}</div>
          </div>
        </div>
      </div>
    {% endif %}

    <div class="rd-story-content rd-reveal">
      {% if section.settings.eyebrow != blank %}
        <div class="rd-story-eyebrow">{{ section.settings.eyebrow }}</div>
      {% endif %}

      <h2 class="rd-story-heading">{{ section.settings.heading }}</h2>

      {% if section.settings.text != blank %}
        <p class="rd-story-text">{{ section.settings.text }}</p>
      {% endif %}

      {% assign ingredient_blocks = section.blocks | where: 'type', 'ingredient' %}
      {% if ingredient_blocks.size > 0 %}
        <div class="rd-story-ingredients">
          {% for block in ingredient_blocks %}
            <div class="rd-story-ingredient" {{ block.shopify_attributes }}>
              <span class="rd-story-ingredient-emoji">{{ block.settings.emoji }}</span>
              <span class="rd-story-ingredient-name">{{ block.settings.name }}</span>
              <span class="rd-story-ingredient-desc">{{ block.settings.description }}</span>
            </div>
          {% endfor %}
        </div>
      {% endif %}

      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="rd-story-btn">
          {{ section.settings.button_text }}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      {% endif %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Story & Ingredients",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "Why Us"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Nature's Most Powerful <em>Hair Revival</em> Formula</p>",
      "info": "Wrap text in <em> tags for italic gold styling."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body Text",
      "default": "Every product is crafted with carefully sourced botanical ingredients that work in harmony to nourish your scalp, strengthen each strand, and restore your hair's natural radiance."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Our Ingredients"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Show Image Panel",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Leave blank to show a decorative placeholder."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image Alt Text"
    },
    {
      "type": "text",
      "id": "badge_number",
      "label": "Badge Stat Number",
      "default": "97%"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Stat Text",
      "default": "of users reported visibly healthier hair within 30 days"
    },
    {
      "type": "header",
      "content": "Design"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Colour",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top/Bottom",
      "min": 40,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding Horizontal",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "text",
          "id": "emoji",
          "label": "Emoji",
          "default": "🌿"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Ingredient Name",
          "default": "Rosemary"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Short Description",
          "default": "Stimulates growth"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Story & Ingredients",
      "blocks": [
        {
          "type": "ingredient",
          "settings": {
            "emoji": "🌿",
            "name": "Rosemary",
            "description": "Stimulates growth"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "emoji": "🧬",
            "name": "Keratin",
            "description": "Repairs damage"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "emoji": "🫒",
            "name": "Castor Oil",
            "description": "Deep moisture"
          }
        }
      ]
    }
  ]
}
{% endschema %}
