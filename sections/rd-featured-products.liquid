<style>
  /* ── Section wrapper ── */
  .rd-featured-products {
    background: {{ section.settings.bg_color | default: '#ffffff' }};
    padding: {{ section.settings.padding_top | default: 88 }}px {{ section.settings.padding_horizontal | default: 48 }}px;
  }
  .rd-featured-products-inner { max-width: 1280px; margin: 0 auto; }

  /* ── Section header ── */
  .rd-fp-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 48px;
    gap: 20px;
  }
  .rd-fp-eyebrow {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #B8956A;
    margin-bottom: 8px;
  }
  .rd-fp-heading {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 300;
    color: #1A1A1A;
    line-height: 1.15;
  }
  .rd-fp-link {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #555555;
    text-decoration: none;
    border-bottom: 1px solid #D4B896;
    padding-bottom: 2px;
    transition: color 0.3s, border-color 0.3s;
    white-space: nowrap;
  }
  .rd-fp-link:hover { color: #B8956A; border-color: #B8956A; }

  /* ── Grid ── */
  .rd-fp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* ── Card ── */
  .rd-fp-card {
    background: #ffffff;
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    position: relative;
    border: 1px solid rgba(0,0,0,0.05);
    cursor: pointer;
  }
  .rd-fp-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 24px 56px rgba(0,0,0,0.10);
    border-color: transparent;
  }

  /* ── Image area ── */
  .rd-fp-card-img {
    width: 100%;
    aspect-ratio: 1 / 1.1;
    background: linear-gradient(160deg, #F7F3EE 0%, #EDE7DF 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .rd-fp-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .rd-fp-card:hover .rd-fp-card-img img { transform: scale(1.05); }

  /* ── Badge ── */
  .rd-fp-badge {
    position: absolute;
    top: 14px;
    left: 14px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 40px;
    z-index: 2;
  }
  .rd-fp-badge--best { background: #B8956A; color: #ffffff; }
  .rd-fp-badge--new  { background: #1A1A1A; color: #ffffff; }
  .rd-fp-badge--sale { background: #C0392B; color: #ffffff; }

  /* ── Quick add overlay ── */
  .rd-fp-quick {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: rgba(26,26,26,0.92);
    color: #ffffff;
    text-align: center;
    padding: 14px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    transform: translateY(100%);
    transition: transform 0.3s ease;
    text-decoration: none;
    display: block;
    backdrop-filter: blur(4px);
  }
  .rd-fp-card:hover .rd-fp-quick { transform: translateY(0); }
  .rd-fp-quick:hover { background: #B8956A; color: #ffffff; }

  /* ── Card info ── */
  .rd-fp-card-info { padding: 20px 22px 24px; }

  .rd-fp-card-name {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 20px;
    font-weight: 500;
    color: #1A1A1A;
    line-height: 1.25;
    margin-bottom: 4px;
    letter-spacing: 0.2px;
  }
  .rd-fp-card-type {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #B8956A;
    margin-bottom: 14px;
  }
  .rd-fp-card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 12px;
    border-top: 1px solid rgba(0,0,0,0.05);
  }
  .rd-fp-card-price {
    font-size: 16px;
    font-weight: 600;
    color: #1A1A1A;
    letter-spacing: -0.3px;
  }
  .rd-fp-card-price del {
    color: #8A8A8A;
    font-weight: 400;
    font-size: 13px;
    margin-left: 6px;
    text-decoration: line-through;
  }
  .rd-fp-card-rating {
    display: flex;
    align-items: center;
    gap: 3px;
    color: #B8956A;
    font-size: 12px;
    letter-spacing: 1px;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .rd-fp-grid { grid-template-columns: repeat(2, 1fr); gap: 20px; }
  }
  @media (max-width: 640px) {
    .rd-featured-products { padding: 56px 20px; }
    .rd-fp-grid { grid-template-columns: 1fr; gap: 16px; }
    .rd-fp-header { flex-direction: column; align-items: flex-start; gap: 12px; }
    .rd-fp-card:hover { transform: none; box-shadow: none; }
    .rd-fp-quick { transform: translateY(0); background: rgba(26,26,26,0.85); }
  }
</style>

<section class="rd-featured-products">
  <div class="rd-featured-products-inner">

    <div class="rd-fp-header rd-reveal">
      <div>
        {% if section.settings.eyebrow != blank %}
          <div class="rd-fp-eyebrow">{{ section.settings.eyebrow }}</div>
        {% endif %}
        <h2 class="rd-fp-heading">{{ section.settings.heading }}</h2>
      </div>
      {% if section.settings.link_text != blank %}
        <a href="{{ section.settings.link_url | default: routes.collections_url }}" class="rd-fp-link">{{ section.settings.link_text }}</a>
      {% endif %}
    </div>

    <div class="rd-fp-grid">
      {% assign fp_collection = collections[section.settings.collection] %}
      {% assign fp_limit = section.settings.products_count | default: 3 %}

      {% if fp_collection and fp_collection.products.size > 0 %}
        {% for product in fp_collection.products limit: fp_limit %}
          <div class="rd-fp-card rd-reveal">
            <div class="rd-fp-card-img">
              {% if product.compare_at_price > product.price %}
                <span class="rd-fp-badge rd-fp-badge--sale">Sale</span>
              {% elsif product.tags contains 'new' or product.tags contains 'New' %}
                <span class="rd-fp-badge rd-fp-badge--new">New</span>
              {% elsif product.tags contains 'popular' or product.tags contains 'Popular' %}
                <span class="rd-fp-badge rd-fp-badge--best">Popular</span>
              {% endif %}
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | img_url: '600x' }}"
                  alt="{{ product.featured_image.alt | escape | default: product.title }}"
                  loading="lazy"
                  width="{{ product.featured_image.width }}"
                  height="{{ product.featured_image.height }}"
                >
              {% endif %}
              <a href="{{ product.url }}" class="rd-fp-quick">View Product</a>
            </div>
            <div class="rd-fp-card-info">
              <div class="rd-fp-card-name">{{ product.title }}</div>
              {% if product.type != blank %}
                <div class="rd-fp-card-type">{{ product.type }}</div>
              {% endif %}
              <div class="rd-fp-card-bottom">
                <div class="rd-fp-card-price">
                  {{ product.price | money }}
                  {% if product.compare_at_price > product.price %}
                    <del>{{ product.compare_at_price | money }}</del>
                  {% endif %}
                </div>
                {% if section.settings.show_rating %}
                  <div class="rd-fp-card-rating">★★★★★</div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}

      {% else %}
        {% comment %} Fallback: show real products only — skip upsell/protection items {% endcomment %}
        {% assign fp_shown = 0 %}
        {% for product in collections.all.products %}
          {% if fp_shown >= fp_limit %}{% break %}{% endif %}
          {% assign is_upsell = false %}
          {% if product.tags contains 'upsell' or product.tags contains 'Upsell' %}
            {% assign is_upsell = true %}
          {% endif %}
          {% if product.type == 'Shipping Protection' or product.type == 'shipping protection' %}
            {% assign is_upsell = true %}
          {% endif %}
          {% if product.title contains 'Package Protection' or product.title contains 'Shipping Protection' or product.title contains 'Priority Processing' %}
            {% assign is_upsell = true %}
          {% endif %}
          {% unless is_upsell %}
            {% assign fp_shown = fp_shown | plus: 1 %}
            <div class="rd-fp-card rd-reveal">
              <div class="rd-fp-card-img">
                {% if product.compare_at_price > product.price %}
                  <span class="rd-fp-badge rd-fp-badge--sale">Sale</span>
                {% elsif product.tags contains 'new' or product.tags contains 'New' %}
                  <span class="rd-fp-badge rd-fp-badge--new">New</span>
                {% elsif product.tags contains 'popular' or product.tags contains 'Popular' %}
                  <span class="rd-fp-badge rd-fp-badge--best">Popular</span>
                {% endif %}
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.title | escape }}" loading="lazy">
                {% endif %}
                <a href="{{ product.url }}" class="rd-fp-quick">View Product</a>
              </div>
              <div class="rd-fp-card-info">
                <div class="rd-fp-card-name">{{ product.title }}</div>
                {% if product.type != blank %}<div class="rd-fp-card-type">{{ product.type }}</div>{% endif %}
                <div class="rd-fp-card-bottom">
                  <div class="rd-fp-card-price">
                    {{ product.price | money }}
                    {% if product.compare_at_price > product.price %}<del>{{ product.compare_at_price | money }}</del>{% endif %}
                  </div>
                  {% if section.settings.show_rating %}<div class="rd-fp-card-rating">★★★★★</div>{% endif %}
                </div>
              </div>
            </div>
          {% endunless %}
        {% endfor %}
      {% endif %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "Bestsellers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Most Loved Products"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "View All Link Text",
      "default": "View All Products"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "View All Link URL"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Leave blank to show from all products."
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Number of Products",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show Star Rating",
      "default": true
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Colour",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top/Bottom",
      "min": 40,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 88
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding Horizontal",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
