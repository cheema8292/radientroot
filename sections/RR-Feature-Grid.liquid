{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      padding-left: 5rem;
      padding-right: 5rem;
    }
  }

  .rr-features-grid-{{ section.id }} {
    display: grid;
    gap: 30px;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
  }

  /* Responsive Breakpoints */
  @media (max-width: 991px) {
    .rr-features-grid-{{ section.id }} { 
      grid-template-columns: repeat(2, 1fr); 
    }
  }

  @media (max-width: 600px) {
    .rr-features-grid-{{ section.id }} { 
      grid-template-columns: 1fr; 
      gap: 40px; 
    }
  }

  .rr-features-grid-item {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .rr-features-grid-icon-wrapper {
    margin-bottom: 20px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .rr-features-grid-icon-wrapper img, .rr-features-grid-icon-wrapper svg {
    width: auto;
    height: 50px;
    object-fit: contain;
  }

  .rr-features-grid-title {
    font-family: inherit;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 12px 0;
    color: {{ section.settings.color_text }};
  }

  .rr-features-grid-text {
    font-size: 13px;
    line-height: 1.4;
    margin: 0;
    color: {{ section.settings.color_text }};
    max-width: 250px;
    opacity: 0.9;
  }

.rr-features-grid-text p {
    margin: 0;
  }

{%- endstyle -%}

<div class="section-{{ section.id }}-padding" style="background-color: {{ section.settings.color_bg }};">
  <div class="rr-features-grid-{{ section.id }}">
    {%- for block in section.blocks -%}
      <div class="rr-features-grid-item" {{ block.shopify_attributes }}>
        <div class="rr-features-grid-icon-wrapper">
          {%- if block.settings.icon != blank -%}
            {{ block.settings.icon | image_url: width: 100 | image_tag: loading: 'lazy' }}
          {%- else -%}
            {% comment %} Default fallback if no image uploaded {% endcomment %}
            <svg viewBox="0 0 24 24" width="50" height="50" stroke="currentColor" stroke-width="1" fill="none"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
          {%- endif -%}
        </div>
        <h3 class="rr-features-grid-title">{{ block.settings.title }}</h3>
        <div class="rr-features-grid-text">{{ block.settings.text }}</div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "RR Icons Grid",
  "settings": [
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns per row (Desktop)",
      "default": 4
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RR Feature Grid",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "SALON QUALITY",
            "text": "<p>Premium affordable luxury quality salon/pro grade results and formulas</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "CRUELTY FREE",
            "text": "<p>All of our product are cruelty free and made with care</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "HAND TESTED AND CREATED",
            "text": "<p>Each product has been tested by a 30+ year hairstylist</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "QUALITY RESULTS",
            "text": "<p>Our products are tested on models, celebs clients and undergoes specific standards and quality before launching.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}