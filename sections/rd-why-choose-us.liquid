{%- liquid
  assign bg_color            = section.settings.bg_color
  assign heading_color       = section.settings.heading_color
  assign eyebrow_color       = section.settings.eyebrow_color
  assign subheading_color    = section.settings.subheading_color
  assign card_bg             = section.settings.card_bg_color
  assign card_heading_color  = section.settings.card_heading_color
  assign card_text_color     = section.settings.card_text_color
  assign icon_color          = section.settings.icon_color
  assign icon_bg             = section.settings.icon_bg_color
  assign padding_top         = section.settings.padding_top
  assign padding_bottom      = section.settings.padding_bottom
  assign padding_horizontal  = section.settings.padding_horizontal
-%}

<style>
  #shopify-section-{{ section.id }} .rd-wcu {
    background-color: {{ bg_color }};
    padding: {{ padding_top }}px {{ padding_horizontal }}px {{ padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .rd-wcu__inner {
    max-width: 1300px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .rd-wcu__header {
    text-align: center;
    margin-bottom: 5rem;
  }

  #shopify-section-{{ section.id }} .rd-wcu__eyebrow {
    display: inline-block;
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ eyebrow_color }};
    margin: 0 0 1.2rem;
    font-family: var(--font-body-family);
  }

  #shopify-section-{{ section.id }} .rd-wcu__heading {
    font-size: clamp(2.8rem, 3.8vw, 4.4rem);
    font-weight: 700;
    color: {{ heading_color }};
    margin: 0 0 1.6rem;
    line-height: 1.15;
    font-family: var(--font-heading-family);
    letter-spacing: var(--letter-spacing-heading);
  }

  #shopify-section-{{ section.id }} .rd-wcu__subheading {
    font-size: 1.65rem;
    color: {{ subheading_color }};
    max-width: 62rem;
    margin: 0 auto;
    line-height: 1.75;
    font-family: var(--font-body-family);
  }

  #shopify-section-{{ section.id }} .rd-wcu__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.4rem;
  }

  #shopify-section-{{ section.id }} .rd-wcu__card {
    background: {{ card_bg }};
    border-radius: 1.6rem;
    padding: 3.2rem 2.8rem;
    display: flex;
    flex-direction: column;
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid transparent;
  }

  #shopify-section-{{ section.id }} .rd-wcu__card:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.08);
    border-color: rgba(184, 149, 106, 0.2);
  }

  #shopify-section-{{ section.id }} .rd-wcu__icon-wrap {
    width: 5.6rem;
    height: 5.6rem;
    border-radius: 1.4rem;
    background: {{ icon_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
    flex-shrink: 0;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  #shopify-section-{{ section.id }} .rd-wcu__icon-wrap svg {
    width: 2.6rem;
    height: 2.6rem;
    stroke: {{ icon_color }};
    fill: none;
    stroke-width: 1.75;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  #shopify-section-{{ section.id }} .rd-wcu__card-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: {{ card_heading_color }};
    margin: 0 0 0.8rem;
    font-family: var(--font-heading-family);
    line-height: 1.3;
    letter-spacing: var(--letter-spacing-heading);
  }

  #shopify-section-{{ section.id }} .rd-wcu__card-desc {
    font-size: 1.45rem;
    color: {{ card_text_color }};
    line-height: 1.75;
    margin: 0;
    font-family: var(--font-body-family);
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .rd-wcu__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .rd-wcu {
      padding: {{ padding_top | divided_by: 1.6 | round }}px 2rem {{ padding_bottom | divided_by: 1.6 | round }}px;
    }

    #shopify-section-{{ section.id }} .rd-wcu__grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.6rem;
    }

    #shopify-section-{{ section.id }} .rd-wcu__card {
      padding: 2.4rem 2rem;
    }

    #shopify-section-{{ section.id }} .rd-wcu__header {
      margin-bottom: 3.2rem;
    }
  }

  @media screen and (max-width: 479px) {
    #shopify-section-{{ section.id }} .rd-wcu__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<section class="rd-wcu" {{ section.shopify_attributes }}>
  <div class="rd-wcu__inner">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="rd-wcu__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="rd-wcu__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="rd-wcu__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="rd-wcu__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="rd-wcu__grid">
        {%- for block in section.blocks -%}
          <div class="rd-wcu__card" {{ block.shopify_attributes }}>
            <div class="rd-wcu__icon-wrap">
              {%- case block.settings.icon -%}
                {%- when 'leaf' -%}
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
                {%- when 'shield' -%}
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                {%- when 'check' -%}
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                {%- when 'heart' -%}
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                {%- when 'flask' -%}
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M9 3h6v7l4 11H5L9 10V3z"/><line x1="6.25" y1="14" x2="17.75" y2="14"/></svg>
                {%- when 'award' -%}
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
                {%- when 'star' -%}
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                {%- when 'truck' -%}
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                {%- when 'droplets' -%}
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"/></svg>
                {%- when 'recycle' -%}
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><polyline points="1.5 8.5 1.5 3.5 6.5 3.5"/><path d="M1.5 3.5l5 5c1.33-3 4.17-5 7.5-5a9 9 0 0 1 9 9"/><polyline points="22.5 15.5 22.5 20.5 17.5 20.5"/><path d="M22.5 20.5l-5-5c-1.33 3-4.17 5-7.5 5a9 9 0 0 1-9-9"/></svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {%- endcase -%}
            </div>
            <h3 class="rd-wcu__card-title">{{ block.settings.title }}</h3>
            {%- if block.settings.description != blank -%}
              <p class="rd-wcu__card-desc">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Why Choose Us",
  "tag": "section",
  "class": "section-rd-why-choose-us",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Section Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Why Choose Us"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Radéant Difference"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We've crafted every formula with one goal in mind — giving you the healthiest hair of your life."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow color",
      "default": "#B8956A"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card background",
      "default": "#F7F3EE"
    },
    {
      "type": "color",
      "id": "card_heading_color",
      "label": "Card title color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card description color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#B8956A"
    },
    {
      "type": "color",
      "id": "icon_bg_color",
      "label": "Icon background",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 20,
      "max": 160,
      "step": 4,
      "default": 88,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 20,
      "max": 160,
      "step": 4,
      "default": 88,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding horizontal",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "reason",
      "name": "Reason Card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "leaf",     "label": "Leaf / Natural" },
            { "value": "shield",   "label": "Shield / Protection" },
            { "value": "check",    "label": "Checkmark / Verified" },
            { "value": "heart",    "label": "Heart / Care" },
            { "value": "flask",    "label": "Flask / Science" },
            { "value": "award",    "label": "Award / Quality" },
            { "value": "star",     "label": "Star / Excellence" },
            { "value": "truck",    "label": "Truck / Shipping" },
            { "value": "droplets", "label": "Droplets / Moisture" },
            { "value": "recycle",  "label": "Recycle / Eco-Friendly" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Our Promise"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "We stand behind every product with our satisfaction guarantee."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us",
      "blocks": [
        {
          "type": "reason",
          "settings": {
            "icon": "leaf",
            "title": "100% Natural Ingredients",
            "description": "Every ingredient is carefully sourced from nature. No synthetic chemicals, no harsh additives — just pure botanical goodness."
          }
        },
        {
          "type": "reason",
          "settings": {
            "icon": "shield",
            "title": "Dermatologist Tested",
            "description": "All our formulas are clinically tested and dermatologist-approved to be safe and effective for all hair and scalp types."
          }
        },
        {
          "type": "reason",
          "settings": {
            "icon": "flask",
            "title": "Science-Backed Formulas",
            "description": "Our cosmetic scientists combine ancient botanical wisdom with modern hair science for results you can see and feel."
          }
        },
        {
          "type": "reason",
          "settings": {
            "icon": "award",
            "title": "Award-Winning Results",
            "description": "With over 137,000 five-star reviews, our products have earned the trust of customers across the globe."
          }
        },
        {
          "type": "reason",
          "settings": {
            "icon": "heart",
            "title": "Cruelty-Free & Vegan",
            "description": "We never test on animals. Our entire range is 100% vegan and cruelty-free, because we care about all living things."
          }
        },
        {
          "type": "reason",
          "settings": {
            "icon": "truck",
            "title": "Fast & Free Shipping",
            "description": "Orders over $50 ship free. We process most orders within 24 hours so you get your products fast."
          }
        }
      ]
    }
  ]
}
{% endschema %}
