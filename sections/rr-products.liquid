<style>
  .rr-products {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_vertical }}px {{ section.settings.padding_horizontal }}px;
    font-family: 'Jost', var(--font-body-family), sans-serif;
  }
  .rr-products__inner { max-width: 1340px; margin: 0 auto; }

  .rr-section-header {
    display: flex; align-items: flex-end; justify-content: space-between;
    margin-bottom: 56px; gap: 20px;
  }
  .rr-eyebrow {
    font-size: 11px; font-weight: 500;
    letter-spacing: 3.5px; text-transform: uppercase;
    color: #B8956A; margin-bottom: 10px;
  }
  .rr-heading {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(30px, 3.5vw, 44px);
    font-weight: 300; color: #1A1A1A; margin: 0;
  }
  .rr-link {
    font-size: 11.5px; font-weight: 500;
    letter-spacing: 1.5px; text-transform: uppercase;
    color: #555555; text-decoration: none;
    border-bottom: 1px solid #D4B896; padding-bottom: 2px;
    transition: all 0.3s; white-space: nowrap;
  }
  .rr-link:hover { color: #B8956A; border-color: #B8956A; }

  .rr-products__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: 24px;
  }
  .rr-product-card {
    background: #F7F3EE;
    border-radius: 20px;
    overflow: hidden;
    transition: all 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    position: relative;
    border: 1px solid rgba(0,0,0,0.04);
    text-decoration: none;
    display: block;
  }
  .rr-product-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 32px 80px rgba(0,0,0,0.13);
    border-color: rgba(184,149,106,0.15);
  }
  .rr-product-card__img {
    width: 100%; aspect-ratio: 3/4;
    background: linear-gradient(160deg, #EDE7DF 0%, #e8e0d6 100%);
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
  }
  .rr-product-card__img img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.45s ease;
  }
  .rr-product-card:hover .rr-product-card__img img { transform: scale(1.04); }
  .rr-product-card__img::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.18) 50%, rgba(255,255,255,0) 100%);
    transform: translateX(-100%); transition: transform 0.6s ease;
    pointer-events: none;
  }
  .rr-product-card:hover .rr-product-card__img::after { transform: translateX(100%); }

  .rr-product-badge {
    position: absolute; top: 16px; left: 16px;
    font-size: 8.5px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase;
    padding: 5px 12px; border-radius: 20px; z-index: 2;
  }
  .rr-product-badge--bestseller { background: #B8956A; color: white; }
  .rr-product-badge--new { background: #1A1A1A; color: white; }
  .rr-product-badge--sale { background: #c0392b; color: white; }

  .rr-product-quick-add {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: #1A1A1A; color: white; text-align: center;
    padding: 13px; font-size: 10.5px; font-weight: 500;
    letter-spacing: 2.5px; text-transform: uppercase;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    display: flex; align-items: center; justify-content: center; gap: 8px;
    z-index: 3;
  }
  .rr-product-card:hover .rr-product-quick-add { transform: translateY(0); }

  .rr-product-card__info { padding: 22px 22px 24px; }
  .rr-product-card__name {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 19px; font-weight: 500; color: #1A1A1A;
    margin-bottom: 4px; line-height: 1.2;
    text-decoration: none;
  }
  .rr-product-card__type { font-size: 11px; color: #8A8A8A; letter-spacing: 0.5px; margin-bottom: 12px; }
  .rr-product-card__bottom { display: flex; align-items: center; justify-content: space-between; }
  .rr-product-card__price { font-size: 16px; font-weight: 600; color: #1A1A1A; }
  .rr-product-card__price del { color: #8A8A8A; font-weight: 400; font-size: 13px; margin-left: 5px; }
  .rr-product-card__rating { display: flex; align-items: center; gap: 4px; font-size: 11px; color: #B8956A; }

  @media (max-width: 1200px) { .rr-products__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) {
    .rr-products { padding: 60px 20px; }
    .rr-products__grid { grid-template-columns: 1fr 1fr; gap: 16px; }
    .rr-section-header { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 480px) { .rr-products__grid { grid-template-columns: 1fr; } }
</style>

<section class="rr-products" id="shopify-section-{{ section.id }}">
  <div class="rr-products__inner">

    <div class="rr-section-header">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <div class="rr-eyebrow">{{ section.settings.eyebrow }}</div>
        {%- endif -%}
        <h2 class="rr-heading">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.link_text != blank -%}
        <a href="{{ section.settings.link_url }}" class="rr-link">{{ section.settings.link_text }} →</a>
      {%- endif -%}
    </div>

    <div class="rr-products__grid">
      {%- assign product_list = section.settings.collection.products | default: collections.all.products -%}
      {%- assign count = 0 -%}
      {%- for product in product_list limit: section.settings.products_count -%}
        {%- assign count = count | plus: 1 -%}
        <a href="{{ product.url }}" class="rr-product-card">
          <div class="rr-product-card__img">
            {%- if product.tags contains 'bestseller' or product.tags contains 'Bestseller' -%}
              <span class="rr-product-badge rr-product-badge--bestseller">Bestseller</span>
            {%- elsif product.tags contains 'new' or product.tags contains 'New' -%}
              <span class="rr-product-badge rr-product-badge--new">New</span>
            {%- elsif product.compare_at_price > product.price -%}
              <span class="rr-product-badge rr-product-badge--sale">Sale</span>
            {%- endif -%}

            {%- if product.featured_image != blank -%}
              {{
                product.featured_image
                | image_url: width: 600
                | image_tag:
                  loading: 'lazy',
                  widths: '300,400,600',
                  sizes: '(max-width: 768px) 50vw, 25vw',
                  alt: product.title
              }}
            {%- endif -%}

            <div class="rr-product-quick-add">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><path d="M3 6h18M16 10a4 4 0 01-8 0"/></svg>
              Quick Add
            </div>
          </div>

          <div class="rr-product-card__info">
            <div class="rr-product-card__name">{{ product.title }}</div>
            <div class="rr-product-card__type">{{ product.type }}</div>
            <div class="rr-product-card__bottom">
              <div class="rr-product-card__price">
                {{ product.price | money }}
                {%- if product.compare_at_price > product.price -%}
                  <del>{{ product.compare_at_price | money }}</del>
                {%- endif -%}
              </div>
              {%- if section.settings.show_rating -%}
                <div class="rr-product-card__rating">★★★★★</div>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "RR Featured Products",
  "tag": "section",
  "class": "section-rr-products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Bestsellers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Most Loved Products"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "View All Products"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Number of products",
      "min": 2, "max": 8, "step": 1, "default": 4
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show star rating",
      "default": true
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Padding top/bottom",
      "min": 40, "max": 160, "step": 8,
      "default": 104, "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding horizontal",
      "min": 0, "max": 80, "step": 4,
      "default": 52, "unit": "px"
    }
  ],
  "presets": [
    { "name": "RR Featured Products" }
  ]
}
{% endschema %}
