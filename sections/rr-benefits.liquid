<style>
  .rr-benefits {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_vertical }}px {{ section.settings.padding_horizontal }}px;
    border-bottom: 1px solid rgba(0,0,0,0.04);
    font-family: 'Jost', var(--font-body-family), sans-serif;
  }
  .rr-benefits__inner {
    max-width: 1340px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_most: 4 }}, 1fr);
    gap: 32px;
  }
  .rr-benefit {
    text-align: center;
    padding: 28px 20px;
    background: #FFFFFF;
    border-radius: 16px;
    border: 1px solid rgba(184,149,106,0.1);
    transition: all 0.35s;
  }
  .rr-benefit:hover {
    border-color: rgba(184,149,106,0.3);
    box-shadow: 0 8px 40px rgba(0,0,0,0.06);
    transform: translateY(-3px);
  }
  .rr-benefit__icon {
    width: 52px; height: 52px;
    margin: 0 auto 18px;
    border: 1px solid #D4B896;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: rgba(184,149,106,0.05);
  }
  .rr-benefit__icon svg {
    width: 20px; height: 20px;
    stroke: #B8956A; fill: none;
    stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round;
  }
  .rr-benefit h4 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 17px; font-weight: 500;
    color: #1A1A1A; margin-bottom: 5px;
  }
  .rr-benefit p {
    font-size: 12px; color: #8A8A8A; line-height: 1.6;
  }
  @media (max-width: 1024px) {
    .rr-benefits__inner { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .rr-benefits {
      padding: {{ section.settings.padding_vertical | divided_by: 1.5 | round }}px 20px;
    }
    .rr-benefits__inner { grid-template-columns: 1fr 1fr; gap: 16px; }
  }
</style>

{%- capture icon_shipping -%}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4M4 7l8 4M4 7v10l8 4m0-10v10"/></svg>
{%- endcapture -%}
{%- capture icon_shield -%}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
{%- endcapture -%}
{%- capture icon_chart -%}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
{%- endcapture -%}
{%- capture icon_trending -%}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
{%- endcapture -%}
{%- capture icon_leaf -%}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
{%- endcapture -%}
{%- capture icon_star -%}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
{%- endcapture -%}

<section class="rr-benefits" id="shopify-section-{{ section.id }}">
  <div class="rr-benefits__inner">
    {%- for block in section.blocks -%}
      <div class="rr-benefit" {{ block.shopify_attributes }}>
        <div class="rr-benefit__icon">
          {%- case block.settings.icon -%}
            {%- when 'shipping' -%}{{ icon_shipping }}
            {%- when 'shield' -%}{{ icon_shield }}
            {%- when 'chart' -%}{{ icon_chart }}
            {%- when 'trending' -%}{{ icon_trending }}
            {%- when 'leaf' -%}{{ icon_leaf }}
            {%- when 'star' -%}{{ icon_star }}
            {%- else -%}{{ icon_shield }}
          {%- endcase -%}
        </div>
        <h4>{{ block.settings.title }}</h4>
        {%- if block.settings.text != blank -%}
          <p>{{ block.settings.text }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "RR Benefits Bar",
  "tag": "section",
  "class": "section-rr-benefits",
  "max_blocks": 6,
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F2EDE6"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Padding top/bottom",
      "min": 32, "max": 120, "step": 8,
      "default": 64, "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding horizontal",
      "min": 0, "max": 80, "step": 4,
      "default": 52, "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shipping", "label": "Shipping / Box" },
            { "value": "shield",   "label": "Shield / Protection" },
            { "value": "chart",    "label": "Chart / Results" },
            { "value": "trending", "label": "Trending / Growth" },
            { "value": "leaf",     "label": "Leaf / Natural" },
            { "value": "star",     "label": "Star / Quality" }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Our Promise"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Clean, safe ingredients"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RR Benefits Bar",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "shipping", "title": "Free Shipping",   "text": "On orders over $50" } },
        { "type": "benefit", "settings": { "icon": "leaf",     "title": "100% Natural",    "text": "Clean, safe ingredients" } },
        { "type": "benefit", "settings": { "icon": "chart",    "title": "Proven Results",  "text": "Clinically tested formulas" } },
        { "type": "benefit", "settings": { "icon": "trending", "title": "137K+ Reviews",   "text": "Loved by customers" } }
      ]
    }
  ]
}
{% endschema %}
