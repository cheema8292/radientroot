<style>
  .rd-benefits-bar {
    background: {{ section.settings.bg_color | default: '#F7F3EE' }};
    padding: {{ section.settings.padding_top | default: 56 }}px {{ section.settings.padding_horizontal | default: 48 }}px;
  }
  .rd-benefits-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | default: 4 }}, 1fr);
    gap: 32px;
  }
  .rd-benefit {
    text-align: center;
    padding: 24px 16px;
  }
  .rd-benefit-icon {
    width: 48px;
    height: 48px;
    margin: 0 auto 16px;
    border: 1px solid #D4B896;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rd-benefit-icon svg {
    width: 20px;
    height: 20px;
    color: #B8956A;
  }
  .rd-benefit h4 {
    font-size: 16px;
    font-weight: 500;
    color: #1A1A1A;
    margin-bottom: 4px;
    letter-spacing: 0.5px;
  }
  .rd-benefit p {
    font-size: 12px;
    color: #8A8A8A;
    line-height: 1.6;
  }
  @media (max-width: 1024px) {
    .rd-benefits-inner { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .rd-benefits-bar { padding: 40px 20px; }
    .rd-benefits-inner { grid-template-columns: 1fr; gap: 16px; }
  }
</style>

<section class="rd-benefits-bar">
  <div class="rd-benefits-inner">
    {% for block in section.blocks %}
      {% if block.type == 'benefit' %}
        <div class="rd-benefit rd-reveal" {{ block.shopify_attributes }}>
          <div class="rd-benefit-icon">
            {% if block.settings.icon == 'shipping' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4M4 7l8 4M4 7v10l8 4m0-10v10"/></svg>
            {% elsif block.settings.icon == 'shield' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {% elsif block.settings.icon == 'chart' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            {% elsif block.settings.icon == 'trending' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
            {% elsif block.settings.icon == 'star' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {% elsif block.settings.icon == 'leaf' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
            {% else %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
            {% endif %}
          </div>
          <h4>{{ block.settings.title }}</h4>
          <p>{{ block.settings.description }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Benefits Bar",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Colour",
      "default": "#F7F3EE"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top/Bottom",
      "min": 16,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding Horizontal",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shipping", "label": "Shipping Box" },
            { "value": "shield", "label": "Shield" },
            { "value": "chart", "label": "Chart / Activity" },
            { "value": "trending", "label": "Trending Up" },
            { "value": "star", "label": "Star" },
            { "value": "leaf", "label": "Leaf / Natural" }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit Title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Short description here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits Bar",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "shipping",
            "title": "Free Shipping",
            "description": "On orders over $50"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "leaf",
            "title": "100% Natural",
            "description": "Clean, safe ingredients"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "chart",
            "title": "Proven Results",
            "description": "Clinically tested formulas"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "trending",
            "title": "137K+ Reviews",
            "description": "Loved by customers"
          }
        }
      ]
    }
  ]
}
{% endschema %}
