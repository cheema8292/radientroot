{%- liquid
  assign bg_color         = section.settings.bg_color | default: '#FFFFFF'
  assign heading_color    = section.settings.heading_color | default: '#1A1A1A'
  assign eyebrow_color    = section.settings.eyebrow_color | default: '#B8956A'
  assign card_bg          = section.settings.card_bg_color | default: '#FFFFFF'
  assign quote_color      = section.settings.quote_color | default: '#F0E8DC'
  assign text_color       = section.settings.text_color | default: '#2D2D2D'
  assign star_color       = section.settings.star_color | default: '#B8956A'
  assign name_color       = section.settings.name_color | default: '#1A1A1A'
  assign meta_color       = section.settings.meta_color | default: '#8A8A8A'
  assign padding_top      = section.settings.padding_top | default: 88
  assign padding_h        = section.settings.padding_horizontal | default: 48
-%}

<style>
  #shopify-section-{{ section.id }} .rd-testimonials {
    background-color: {{ bg_color }};
    padding: {{ padding_top }}px {{ padding_h }}px;
  }

  #shopify-section-{{ section.id }} .rd-testimonials__inner {
    max-width: 1300px;
    margin: 0 auto;
  }

  /* ── Header row ── */
  #shopify-section-{{ section.id }} .rd-testimonials__top {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2.4rem;
    margin-bottom: 5.6rem;
  }

  #shopify-section-{{ section.id }} .rd-testimonials__eyebrow {
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: {{ eyebrow_color }};
    margin: 0 0 1rem;
    font-family: var(--font-body-family);
  }

  #shopify-section-{{ section.id }} .rd-testimonials__heading {
    font-size: clamp(2.8rem, 3.6vw, 4.4rem);
    font-weight: 700;
    color: {{ heading_color }};
    margin: 0;
    line-height: 1.12;
    font-family: var(--font-heading-family);
    letter-spacing: var(--letter-spacing-heading);
  }

  #shopify-section-{{ section.id }} .rd-testimonials__summary {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
    flex-shrink: 0;
    padding-bottom: 0.4rem;
  }

  #shopify-section-{{ section.id }} .rd-testimonials__summary-stars {
    display: flex;
    gap: 0.3rem;
  }

  #shopify-section-{{ section.id }} .rd-testimonials__summary-stars svg {
    width: 1.8rem;
    height: 1.8rem;
    fill: {{ star_color }};
  }

  #shopify-section-{{ section.id }} .rd-testimonials__summary-rating {
    font-size: 2.6rem;
    font-weight: 800;
    color: {{ heading_color }};
    font-family: var(--font-heading-family);
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .rd-testimonials__summary-count {
    font-size: 1.3rem;
    color: {{ meta_color }};
    font-family: var(--font-body-family);
  }

  #shopify-section-{{ section.id }} .rd-testimonials__link {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: {{ meta_color }};
    text-decoration: none;
    border-bottom: 1.5px solid {{ eyebrow_color }};
    padding-bottom: 2px;
    transition: color 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
    align-self: flex-end;
    margin-left: 1.6rem;
  }

  #shopify-section-{{ section.id }} .rd-testimonials__link:hover {
    color: {{ eyebrow_color }};
  }

  /* ── Card grid ── */
  #shopify-section-{{ section.id }} .rd-testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.4rem;
  }

  #shopify-section-{{ section.id }} .rd-testimonials__card {
    background: {{ card_bg }};
    border-radius: 2rem;
    padding: 3.6rem 3.2rem;
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.05);
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1), box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  #shopify-section-{{ section.id }} .rd-testimonials__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 56px rgba(0, 0, 0, 0.09);
  }

  /* Decorative large quote mark */
  #shopify-section-{{ section.id }} .rd-testimonials__card::before {
    content: '\201C';
    position: absolute;
    top: -1rem;
    right: 2.4rem;
    font-size: 14rem;
    line-height: 1;
    color: {{ quote_color }};
    font-family: Georgia, serif;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  /* ── Stars ── */
  #shopify-section-{{ section.id }} .rd-testimonials__stars {
    display: flex;
    gap: 0.3rem;
    margin-bottom: 2rem;
    position: relative;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .rd-testimonials__stars svg {
    width: 1.8rem;
    height: 1.8rem;
    fill: {{ star_color }};
  }

  /* ── Review text ── */
  #shopify-section-{{ section.id }} .rd-testimonials__text {
    font-size: 1.65rem;
    font-weight: 400;
    line-height: 1.75;
    color: {{ text_color }};
    font-style: italic;
    flex-grow: 1;
    margin: 0 0 2.8rem;
    position: relative;
    z-index: 1;
    font-family: var(--font-body-family);
  }

  /* ── Author row ── */
  #shopify-section-{{ section.id }} .rd-testimonials__author {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    position: relative;
    z-index: 1;
    border-top: 1px solid rgba(0,0,0,0.06);
    padding-top: 2rem;
  }

  #shopify-section-{{ section.id }} .rd-testimonials__avatar {
    width: 4.6rem;
    height: 4.6rem;
    border-radius: 50%;
    background: linear-gradient(135deg, {{ eyebrow_color }}, #96754A);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    color: #fff;
    font-weight: 700;
    flex-shrink: 0;
    overflow: hidden;
    font-family: var(--font-heading-family);
    box-shadow: 0 2px 8px rgba(184,149,106,0.3);
  }

  #shopify-section-{{ section.id }} .rd-testimonials__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .rd-testimonials__name {
    font-size: 1.5rem;
    font-weight: 700;
    color: {{ name_color }};
    font-family: var(--font-body-family);
    margin: 0 0 0.3rem;
  }

  #shopify-section-{{ section.id }} .rd-testimonials__verified {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 1.15rem;
    color: #4CAF50;
    font-family: var(--font-body-family);
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .rd-testimonials__verified svg {
    width: 1.3rem;
    height: 1.3rem;
    fill: #4CAF50;
    flex-shrink: 0;
  }

  /* ── Responsive ── */
  @media screen and (max-width: 1024px) {
    #shopify-section-{{ section.id }} .rd-testimonials__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .rd-testimonials {
      padding: {{ padding_top | divided_by: 1.6 | round }}px 2rem;
    }

    #shopify-section-{{ section.id }} .rd-testimonials__top {
      flex-direction: column;
      align-items: flex-start;
      gap: 2rem;
      margin-bottom: 3.6rem;
    }

    #shopify-section-{{ section.id }} .rd-testimonials__summary {
      align-items: flex-start;
      flex-direction: row;
      align-items: center;
      gap: 1.6rem;
    }

    #shopify-section-{{ section.id }} .rd-testimonials__link {
      margin-left: 0;
      align-self: flex-start;
    }

    #shopify-section-{{ section.id }} .rd-testimonials__grid {
      grid-template-columns: 1fr;
    }

    #shopify-section-{{ section.id }} .rd-testimonials__card {
      padding: 2.8rem 2.4rem;
    }
  }
</style>

{%- assign star_svg -%}
<svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
{%- endassign -%}

<section class="rd-testimonials" {{ section.shopify_attributes }}>
  <div class="rd-testimonials__inner">

    <div class="rd-testimonials__top">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="rd-testimonials__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="rd-testimonials__heading">{{ section.settings.heading }}</h2>
      </div>

      <div style="display:flex;align-items:flex-end;gap:2.4rem;">
        <div class="rd-testimonials__summary">
          <div class="rd-testimonials__summary-stars">
            {%- for i in (1..5) -%}{{ star_svg }}{%- endfor -%}
          </div>
          <div class="rd-testimonials__summary-rating">4.8</div>
          <div class="rd-testimonials__summary-count">137,000+ reviews</div>
        </div>

        {%- if section.settings.link_text != blank -%}
          <a href="{{ section.settings.link_url }}" class="rd-testimonials__link">
            {{ section.settings.link_text }}
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="rd-testimonials__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'testimonial' -%}
          <div class="rd-testimonials__card" {{ block.shopify_attributes }}>
            <div class="rd-testimonials__stars">
              {%- assign stars = block.settings.rating | default: 5 -%}
              {%- for i in (1..stars) -%}{{ star_svg }}{%- endfor -%}
            </div>

            <p class="rd-testimonials__text">"{{ block.settings.review_text }}"</p>

            <div class="rd-testimonials__author">
              <div class="rd-testimonials__avatar">
                {%- if block.settings.avatar -%}
                  <img src="{{ block.settings.avatar | image_url: width: 92 }}" alt="{{ block.settings.author_name | escape }}" loading="lazy" width="46" height="46">
                {%- else -%}
                  {{ block.settings.author_name | slice: 0 | upcase }}
                {%- endif -%}
              </div>
              <div>
                <div class="rd-testimonials__name">{{ block.settings.author_name }}</div>
                {%- if block.settings.verified -%}
                  <div class="rd-testimonials__verified">
                    <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
                    </svg>
                    Verified Purchase
                  </div>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Section Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "Real Results"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text",
      "default": "Read All Reviews"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#F7F3EE"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow color",
      "default": "#B8956A"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "quote_color",
      "label": "Decorative quote color",
      "default": "#F0E8DC"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Review text color",
      "default": "#2D2D2D"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#B8956A"
    },
    {
      "type": "color",
      "id": "name_color",
      "label": "Author name color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "meta_color",
      "label": "Meta / link color",
      "default": "#8A8A8A"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top/Bottom",
      "min": 40,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding Horizontal",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "This product has transformed my hair. Highly recommend!"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author Name",
          "default": "Happy Customer"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Author Avatar",
          "info": "Leave blank to show initials."
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show Verified Badge",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "review_text": "My hair has never felt this soft and healthy. After just two weeks, I noticed less breakage and more shine. This is the real deal.",
            "author_name": "Sarah M.",
            "verified": true
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "review_text": "I was skeptical at first but the results are undeniable. My hair is noticeably fuller and stronger. Worth every penny.",
            "author_name": "Jessica L.",
            "verified": true
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "review_text": "Finally a shampoo that actually delivers on its promises. The rosemary scent is amazing and my scalp feels so healthy.",
            "author_name": "Priya K.",
            "verified": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
