      "label": "Eyebrow color",
      "default": "#B8956A"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "question_color",
      "label": "Question text color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Number color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "answer_color",
