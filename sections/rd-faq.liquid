{%- liquid
  assign bg_color         = section.settings.bg_color
  assign heading_color    = section.settings.heading_color
  assign eyebrow_color    = section.settings.eyebrow_color
  assign subheading_color = section.settings.subheading_color
  assign question_color   = section.settings.question_color
  assign answer_color     = section.settings.answer_color
  assign number_color     = section.settings.number_color
  assign border_color     = section.settings.border_color
  assign accent_color     = section.settings.icon_color
  assign active_bg        = section.settings.active_bg_color
  assign padding_top      = section.settings.padding_top
  assign padding_bottom   = section.settings.padding_bottom
  assign padding_h        = section.settings.padding_horizontal
  assign max_width        = section.settings.content_max_width
-%}

<style>
  #shopify-section-{{ section.id }} .rd-faq {
    background-color: {{ bg_color }};
    padding: {{ padding_top }}px {{ padding_h }}px {{ padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .rd-faq__inner {
    max-width: {{ max_width }}px;
    margin: 0 auto;
  }

  /* ── Header ── */
  #shopify-section-{{ section.id }} .rd-faq__header {
    text-align: center;
    margin-bottom: 6.4rem;
  }

  #shopify-section-{{ section.id }} .rd-faq__eyebrow {
    display: inline-block;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: {{ eyebrow_color }};
    margin: 0 0 1.4rem;
    font-family: var(--font-body-family);
  }

  #shopify-section-{{ section.id }} .rd-faq__heading {
    font-size: clamp(3rem, 4vw, 4.8rem);
    font-weight: 700;
    color: {{ heading_color }};
    margin: 0 0 1.6rem;
    line-height: 1.12;
    font-family: var(--font-heading-family);
    letter-spacing: var(--letter-spacing-heading);
  }

  #shopify-section-{{ section.id }} .rd-faq__subheading {
    font-size: 1.7rem;
    color: {{ subheading_color }};
    max-width: 54rem;
    margin: 0 auto;
    line-height: 1.7;
    font-family: var(--font-body-family);
  }

  /* ── Accordion list ── */
  #shopify-section-{{ section.id }} .rd-faq__list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  #shopify-section-{{ section.id }} .rd-faq__item {
    border-bottom: 1px solid {{ border_color }};
    background: transparent;
    transition: background 0.3s ease;
  }

  #shopify-section-{{ section.id }} .rd-faq__item:first-child {
    border-top: 1px solid {{ border_color }};
  }

  #shopify-section-{{ section.id }} .rd-faq__item.is-open {
    background-color: {{ active_bg }};
  }

  /* ── Question row ── */
  #shopify-section-{{ section.id }} .rd-faq__question {
    display: grid;
    grid-template-columns: 5.6rem 1fr 3.2rem;
    align-items: center;
    gap: 2rem;
    width: 100%;
    padding: 2.8rem 2.4rem 2.8rem 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
  }

  #shopify-section-{{ section.id }} .rd-faq__number {
    font-size: clamp(2.2rem, 2.8vw, 3rem);
    font-weight: 800;
    color: {{ number_color }};
    line-height: 1;
    font-family: var(--font-heading-family);
    letter-spacing: -0.02em;
    transition: color 0.25s ease;
    text-align: right;
    opacity: 0.18;
    user-select: none;
  }

  #shopify-section-{{ section.id }} .rd-faq__item.is-open .rd-faq__number {
    color: {{ accent_color }};
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .rd-faq__question-text {
    font-size: 1.75rem;
    font-weight: 600;
    color: {{ question_color }};
    font-family: var(--font-heading-family);
    letter-spacing: -0.01em;
    line-height: 1.4;
    transition: color 0.2s ease;
  }

  #shopify-section-{{ section.id }} .rd-faq__question:hover .rd-faq__question-text {
    color: {{ accent_color }};
  }

  #shopify-section-{{ section.id }} .rd-faq__chevron {
    flex-shrink: 0;
    width: 3.2rem;
    height: 3.2rem;
    border-radius: 50%;
    border: 1.5px solid {{ border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.25s ease, border-color 0.25s ease;
    color: {{ accent_color }};
  }

  #shopify-section-{{ section.id }} .rd-faq__chevron svg {
    width: 1.4rem;
    height: 1.4rem;
    stroke: currentColor;
    fill: none;
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #shopify-section-{{ section.id }} .rd-faq__item.is-open .rd-faq__chevron {
    background: {{ accent_color }};
    border-color: {{ accent_color }};
    color: #fff;
  }

  #shopify-section-{{ section.id }} .rd-faq__item.is-open .rd-faq__chevron svg {
    transform: rotate(180deg);
  }

  /* ── Answer panel ── */
  #shopify-section-{{ section.id }} .rd-faq__answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.42s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #shopify-section-{{ section.id }} .rd-faq__answer-inner {
    padding: 0 2.4rem 3.2rem calc(5.6rem + 2rem + 2.4rem);
    font-size: 1.6rem;
    color: {{ answer_color }};
    line-height: 1.85;
    font-family: var(--font-body-family);
  }

  #shopify-section-{{ section.id }} .rd-faq__answer-inner p {
    margin: 0 0 1.2rem;
  }

  #shopify-section-{{ section.id }} .rd-faq__answer-inner p:last-child {
    margin-bottom: 0;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .rd-faq {
      padding: {{ padding_top | divided_by: 1.6 | round }}px 2rem {{ padding_bottom | divided_by: 1.6 | round }}px;
    }

    #shopify-section-{{ section.id }} .rd-faq__header {
      margin-bottom: 4rem;
    }

    #shopify-section-{{ section.id }} .rd-faq__question {
      grid-template-columns: 3.6rem 1fr 2.8rem;
      gap: 1.2rem;
      padding: 2.2rem 1.6rem 2.2rem 0;
    }

    #shopify-section-{{ section.id }} .rd-faq__number {
      font-size: 2rem;
    }

    #shopify-section-{{ section.id }} .rd-faq__question-text {
      font-size: 1.6rem;
    }

    #shopify-section-{{ section.id }} .rd-faq__answer-inner {
      padding: 0 1.6rem 2.4rem calc(3.6rem + 1.2rem + 1.6rem);
      font-size: 1.5rem;
    }
  }
</style>

<section class="rd-faq" {{ section.shopify_attributes }}>
  <div class="rd-faq__inner">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="rd-faq__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="rd-faq__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="rd-faq__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="rd-faq__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="rd-faq__list" role="list">
        {%- for block in section.blocks -%}
          <div class="rd-faq__item" {{ block.shopify_attributes }} role="listitem">
            <button
              class="rd-faq__question"
              aria-expanded="false"
              aria-controls="faq-answer-{{ section.id }}-{{ forloop.index }}"
              id="faq-q-{{ section.id }}-{{ forloop.index }}"
            >
              <span class="rd-faq__number" aria-hidden="true">
                {%- assign n = forloop.index -%}
                {%- if n < 10 -%}0{{ n }}{%- else -%}{{ n }}{%- endif -%}
              </span>
              <span class="rd-faq__question-text">{{ block.settings.question }}</span>
              <span class="rd-faq__chevron" aria-hidden="true">
                <svg viewBox="0 0 14 14" xmlns="http://www.w3.org/2000/svg">
                  <polyline points="2 5 7 10 12 5"/>
                </svg>
              </span>
            </button>
            <div
              class="rd-faq__answer"
              id="faq-answer-{{ section.id }}-{{ forloop.index }}"
              role="region"
              aria-labelledby="faq-q-{{ section.id }}-{{ forloop.index }}"
              aria-hidden="true"
            >
              <div class="rd-faq__answer-inner">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

<script>
  (function () {
    var section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;

    section.querySelectorAll('.rd-faq__question').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var item   = btn.closest('.rd-faq__item');
        var answer = item.querySelector('.rd-faq__answer');
        var isOpen = item.classList.contains('is-open');

        /* Close all */
        section.querySelectorAll('.rd-faq__item.is-open').forEach(function (open) {
          open.classList.remove('is-open');
          open.querySelector('.rd-faq__question').setAttribute('aria-expanded', 'false');
          var a = open.querySelector('.rd-faq__answer');
          a.style.maxHeight = null;
          a.setAttribute('aria-hidden', 'true');
        });

        /* Open clicked if it was closed */
        if (!isOpen) {
          item.classList.add('is-open');
          btn.setAttribute('aria-expanded', 'true');
          answer.style.maxHeight = answer.scrollHeight + 'px';
          answer.setAttribute('aria-hidden', 'false');
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "section-rd-faq",
  "max_blocks": 20,
  "settings": [
    {
      "type": "header",
