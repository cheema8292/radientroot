{%- liquid
  assign bg_color         = section.settings.bg_color
  assign heading_color    = section.settings.heading_color
  assign eyebrow_color    = section.settings.eyebrow_color
  assign subheading_color = section.settings.subheading_color
  assign question_color   = section.settings.question_color
  assign answer_color     = section.settings.answer_color
  assign border_color     = section.settings.border_color
  assign icon_color       = section.settings.icon_color
  assign active_bg        = section.settings.active_bg_color
  assign padding_top      = section.settings.padding_top
  assign padding_bottom   = section.settings.padding_bottom
  assign padding_h        = section.settings.padding_horizontal
  assign max_width        = section.settings.content_max_width
-%}

<style>
  #shopify-section-{{ section.id }} .rd-faq {
    background-color: {{ bg_color }};
    padding: {{ padding_top }}px {{ padding_h }}px {{ padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .rd-faq__inner {
    max-width: {{ max_width }}px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .rd-faq__header {
    text-align: center;
    margin-bottom: 5rem;
  }

  #shopify-section-{{ section.id }} .rd-faq__eyebrow {
    display: inline-block;
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ eyebrow_color }};
    margin: 0 0 1.2rem;
    font-family: var(--font-body-family);
  }

  #shopify-section-{{ section.id }} .rd-faq__heading {
    font-size: clamp(2.8rem, 3.6vw, 4.2rem);
    font-weight: 700;
    color: {{ heading_color }};
    margin: 0 0 1.6rem;
    line-height: 1.15;
    font-family: var(--font-heading-family);
    letter-spacing: var(--letter-spacing-heading);
  }

  #shopify-section-{{ section.id }} .rd-faq__subheading {
    font-size: 1.65rem;
    color: {{ subheading_color }};
    max-width: 56rem;
    margin: 0 auto;
    line-height: 1.75;
    font-family: var(--font-body-family);
  }

  /* ── Accordion ── */
  #shopify-section-{{ section.id }} .rd-faq__list {
    border-top: 1px solid {{ border_color }};
  }

  #shopify-section-{{ section.id }} .rd-faq__item {
    border-bottom: 1px solid {{ border_color }};
    overflow: hidden;
    transition: background 0.25s ease;
  }

  #shopify-section-{{ section.id }} .rd-faq__item.is-open {
    background-color: {{ active_bg }};
  }

  #shopify-section-{{ section.id }} .rd-faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    width: 100%;
    padding: 2.4rem 2rem;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-size: 1.7rem;
    font-weight: 600;
    color: {{ question_color }};
    font-family: var(--font-heading-family);
    letter-spacing: var(--letter-spacing-heading);
    line-height: 1.4;
    transition: color 0.2s ease;
  }

  #shopify-section-{{ section.id }} .rd-faq__question:hover {
    color: {{ icon_color }};
  }

  #shopify-section-{{ section.id }} .rd-faq__question-icon {
    flex-shrink: 0;
    width: 3.2rem;
    height: 3.2rem;
    border-radius: 50%;
    border: 1.5px solid {{ border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.25s ease, border-color 0.25s ease, transform 0.25s ease;
    color: {{ icon_color }};
  }

  #shopify-section-{{ section.id }} .rd-faq__question-icon svg {
    width: 1.4rem;
    height: 1.4rem;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #shopify-section-{{ section.id }} .rd-faq__item.is-open .rd-faq__question-icon {
    background: {{ icon_color }};
    border-color: {{ icon_color }};
    color: #fff;
  }

  #shopify-section-{{ section.id }} .rd-faq__item.is-open .rd-faq__question-icon svg {
    transform: rotate(45deg);
  }

  #shopify-section-{{ section.id }} .rd-faq__answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #shopify-section-{{ section.id }} .rd-faq__answer-inner {
    padding: 0 2rem 2.4rem;
    font-size: 1.55rem;
    color: {{ answer_color }};
    line-height: 1.8;
    font-family: var(--font-body-family);
  }

  #shopify-section-{{ section.id }} .rd-faq__answer-inner p {
    margin: 0 0 1rem;
  }

  #shopify-section-{{ section.id }} .rd-faq__answer-inner p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .rd-faq {
      padding: {{ padding_top | divided_by: 1.6 | round }}px 2rem {{ padding_bottom | divided_by: 1.6 | round }}px;
    }

    #shopify-section-{{ section.id }} .rd-faq__header {
      margin-bottom: 3.2rem;
    }

    #shopify-section-{{ section.id }} .rd-faq__question {
      font-size: 1.55rem;
      padding: 2rem 1.6rem;
    }

    #shopify-section-{{ section.id }} .rd-faq__answer-inner {
      padding: 0 1.6rem 2rem;
      font-size: 1.45rem;
    }
  }
</style>

<section class="rd-faq" {{ section.shopify_attributes }}>
  <div class="rd-faq__inner">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="rd-faq__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="rd-faq__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="rd-faq__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="rd-faq__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="rd-faq__list" role="list">
        {%- for block in section.blocks -%}
          <div class="rd-faq__item" {{ block.shopify_attributes }} role="listitem">
            <button
              class="rd-faq__question"
              aria-expanded="false"
              aria-controls="faq-answer-{{ section.id }}-{{ forloop.index }}"
              id="faq-question-{{ section.id }}-{{ forloop.index }}"
            >
              <span>{{ block.settings.question }}</span>
              <span class="rd-faq__question-icon" aria-hidden="true">
                <svg viewBox="0 0 14 14" xmlns="http://www.w3.org/2000/svg">
                  <line x1="7" y1="1" x2="7" y2="13"/>
                  <line x1="1" y1="7" x2="13" y2="7"/>
                </svg>
              </span>
            </button>
            <div
              class="rd-faq__answer"
              id="faq-answer-{{ section.id }}-{{ forloop.index }}"
              role="region"
              aria-labelledby="faq-question-{{ section.id }}-{{ forloop.index }}"
              aria-hidden="true"
            >
              <div class="rd-faq__answer-inner">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

<script>
  (function () {
    var section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;

    var questions = section.querySelectorAll('.rd-faq__question');

    questions.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var item   = btn.closest('.rd-faq__item');
        var answer = item.querySelector('.rd-faq__answer');
        var isOpen = item.classList.contains('is-open');

        /* Close all open items */
        section.querySelectorAll('.rd-faq__item.is-open').forEach(function (openItem) {
          openItem.classList.remove('is-open');
          openItem.querySelector('.rd-faq__question').setAttribute('aria-expanded', 'false');
          openItem.querySelector('.rd-faq__answer').style.maxHeight = null;
          openItem.querySelector('.rd-faq__answer').setAttribute('aria-hidden', 'true');
        });

        /* Open the clicked item if it was closed */
        if (!isOpen) {
          item.classList.add('is-open');
          btn.setAttribute('aria-expanded', 'true');
          answer.style.maxHeight = answer.scrollHeight + 'px';
          answer.setAttribute('aria-hidden', 'false');
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "section-rd-faq",
  "max_blocks": 20,
  "settings": [
    {
      "type": "header",
      "content": "Section Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Got Questions?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Everything you need to know about our products and your hair care journey."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#F7F3EE"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow color",
      "default": "#B8956A"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "question_color",
      "label": "Question text color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "answer_color",
      "label": "Answer text color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Divider line color",
      "default": "#E5DDD4"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon / accent color",
      "default": "#B8956A"
    },
    {
      "type": "color",
      "id": "active_bg_color",
      "label": "Open item background",
      "default": "#EDE8E1"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 480,
      "max": 1100,
      "step": 20,
      "default": 840,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 20,
      "max": 160,
      "step": 4,
      "default": 88,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 20,
      "max": 160,
      "step": 4,
      "default": 88,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding horizontal",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long until I see results?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Most customers notice visible improvements within 2–4 weeks of consistent use. For best results, use daily and allow the formula to fully absorb.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "How long until I see results?",
            "answer": "<p>Most customers notice visible improvements within 2–4 weeks of consistent use. For best results, use our shampoo and conditioner together daily and allow the formula to fully absorb before rinsing.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Are your products suitable for all hair types?",
            "answer": "<p>Yes! Our formulas are designed to work for all hair types — straight, wavy, curly, coily, fine, thick, color-treated, or natural. The gentle botanical blend nourishes without weighing hair down.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Are your products sulfate and paraben free?",
            "answer": "<p>Absolutely. Every Radéant product is 100% free from sulfates, parabens, silicones, and artificial fragrances. We use only clean, plant-derived ingredients that are gentle on your scalp and hair.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How do I use the rosemary shampoo?",
            "answer": "<p>Apply a generous amount to wet hair and gently massage into your scalp for 60 seconds to activate the rosemary. Leave on for 2–3 minutes to allow the ingredients to absorb, then rinse thoroughly with cool water.</p>"
