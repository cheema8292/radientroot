    "rd_faq": {
      "type": "rd-faq",
      "blocks": {
        "faq_1": {
          "type": "faq_item",
          "settings": {
            "question": "How long until I see results?",
            "answer": "<p>Most customers notice visible improvements within 2–4 weeks of consistent use. For best results, use our shampoo and conditioner together daily and allow the formula to fully absorb before rinsing.</p>"
          }
        },
        "faq_2": {
          "type": "faq_item",
          "settings": {
            "question": "Are your products suitable for all hair types?",
            "answer": "<p>Yes! Our formulas are designed to work for all hair types — straight, wavy, curly, coily, fine, thick, color-treated, or natural. The gentle botanical blend nourishes without weighing hair down.</p>"
          }
        },
        "faq_3": {
          "type": "faq_item",
          "settings": {
            "question": "Are your products sulfate and paraben free?",
            "answer": "<p>Absolutely. Every Radéant product is 100% free from sulfates, parabens, silicones, and artificial fragrances. We use only clean, plant-derived ingredients that are gentle on your scalp and hair.</p>"
          }
        },
        "faq_4": {
          "type": "faq_item",
          "settings": {
            "question": "How do I use the rosemary shampoo?",
            "answer": "<p>Apply a generous amount to wet hair and gently massage into your scalp for 60 seconds to activate the rosemary. Leave on for 2–3 minutes, then rinse thoroughly with cool water.</p>"
          }
        },
        "faq_5": {
          "type": "faq_item",
          "settings": {
            "question": "Do you offer free shipping?",
            "answer": "<p>Yes — we offer free standard shipping on all orders over $50. Orders typically ship within 1–2 business days and arrive in 3–7 business days depending on your location.</p>"
          }
        },
