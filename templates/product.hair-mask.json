onger. Smoother. Visibly Revived.<\/strong><\/p>","margin_top":0,"margin_bottom":0,"paragraph_color":"#333333"}}},"block_order":["paragraph_wQ3BMt"],"name":"Image with Text","settings":{"use_theme_colors":false,"inverse_theme_colors":false,"image_position":"left","image_position_mobile":"top","text_align":"left","center_align_with_media":true,"column_width":50,"margin_top_mobile":40,"margin_bottom_mobile":40,"padding_top_mobile":40,"padding_bottom_mobile":40,"container_padding_mobile":20,"padding_top_desktop":0,"padding_bottom_desktop":0,"container_padding_desktop":0,"content_spacing":30,"desktop_content_spacing":40,"section_border_radius":0,"section_max_width":1200,"contain_section":false,"container_max_width":1200,"container_bg_color":"#ffffff","enable_container_gradient":false,"container_gradient_background":"linear-gradient(135deg, rgba(255, 255, 255, 1), rgba(248, 248, 248, 1) 100%)","container_padding_vertical":40,"container_padding_horizontal":40,"container_padding_vertical_mobile":30,"container_padding_horizontal_mobile":20,"enable_border":false,"border_width":1,"border_style":"solid","border_color":"#e5e7eb","border_radius":8,"enable_shadow":false,"heading":"Targeted Repair for Dry & Damaged Strands","heading_accent":"","image":"shopify:\/\/shop_images\/ChatGPT_Image_Feb_16_2026_09_10_43_PM.png","enable_image_fade_mask":false,"video_autoplay":true,"video_loop":true,"video_muted":true,"video_controls":false,"heading_font_size_mobile":2.4,"heading_font_size_desktop":3,"text_font_size_mobile":1.5,"text_font_size_desktop":1.5,"content_elements_spacing":15,"desktop_content_elements_spacing":20,"heading_bottom_margin":0,"desktop_heading_bottom_margin":0,"text_bottom_margin":25,"desktop_text_bottom_margin":25,"text_padding_vertical":0,"text_padding_left":0,"text_padding_right":0,"mobile_text_padding_vertical":0,"mobile_text_padding_horizontal":0,"button_padding_vertical":12,"button_padding_horizontal":24,"button_border_radius":4,"background_color":"#ffffff","backg